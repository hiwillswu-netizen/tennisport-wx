/** app.wxss **/
@font-face {
  font-family: 'Playfair Display';
  src: url('https://cdn.jsdelivr.net/fontsource/fonts/playfair-display:vf@latest/latin-wght-normal.woff2') format('woff2');
  font-weight: 700;
  font-display: swap;
}

@font-face {
  font-family: 'Manrope';
  src: url('https://cdn.jsdelivr.net/fontsource/fonts/manrope:vf@latest/latin-wght-normal.woff2') format('woff2');
  font-weight: 400;
  font-display: swap;
}

page {
  --tf-display: 'Playfair Display', 'Songti SC', 'STSong', serif;
  --tf-body: 'Manrope', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  --tf-ink: #233a35;
  --tf-ink-soft: #5f716b;
  --tf-muted: #8a9a93;
  --tf-line: #dde8e1;
  --tf-surface: #f8fbf6;
  --tf-surface-raised: #ffffff;
  --tf-primary: #10a873;
  --tf-primary-deep: #0f7a58;
  --tf-primary-soft: #e8f8ee;
  --tf-accent: #ff8f2f;
  --tf-accent-deep: #c45c18;
  --tf-blue: #3979d6;
  --tf-danger: #d83434;
  --tf-shadow: rgba(23, 70, 55, 0.16);
  --tf-oklch-ink: oklch(22% 0.035 165);
  --tf-oklch-primary: oklch(54% 0.17 166);
  --tf-oklch-accent: oklch(70% 0.22 40);
  --weui-BRAND: #10a873;
  --weui-BRAND-DARK: #0f7a58;
  --weui-BRAND-LIGHT: #e8f8ee;
  min-height: 100%;
  background: linear-gradient(145deg, #f8fbf6, #f2faf6 46%, #fbf8f1);
  background:
    linear-gradient(145deg, oklch(98% 0.035 118), oklch(95% 0.04 176) 46%, oklch(97% 0.035 78));
  color: var(--tf-ink);
  font-family: var(--tf-body);
  font-size: 28rpx;
}

.container {
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

.display-font {
  font-family: var(--tf-display);
}

.lucide-icon,
.icon-img {
  width: 30rpx;
  height: 30rpx;
  flex-shrink: 0;
  display: block;
}

.empty-icon-img {
  width: 112rpx;
  height: 112rpx;
  margin-bottom: 24rpx;
}

.btn-primary {
  background: linear-gradient(135deg, var(--tf-primary), var(--tf-primary-deep));
  color: oklch(100% 0 0);
  border: none;
  border-radius: 999rpx;
  padding: 22rpx 44rpx;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
  box-shadow: 0 18rpx 36rpx var(--tf-shadow);
}

.btn-primary:active {
  transform: translateY(2rpx) scale(0.99);
}

.btn-secondary {
  background: oklch(100% 0.01 105 / 0.82);
  color: var(--tf-primary-deep);
  border: 2rpx solid oklch(82% 0.08 166);
  border-radius: 999rpx;
  padding: 20rpx 44rpx;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
}

.card {
  background: oklch(100% 0.01 105 / 0.9);
  border: 1rpx solid oklch(94% 0.03 155);
  border-radius: 20rpx;
  box-shadow: 0 20rpx 60rpx var(--tf-shadow);
}

.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.tag-indoor {
  background: oklch(93% 0.06 235);
  color: oklch(42% 0.14 235);
}

.tag-outdoor {
  background: var(--tf-primary-soft);
  color: var(--tf-primary-deep);
}

.tag-default {
  background: oklch(94% 0.025 105);
  color: var(--tf-ink-soft);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  text-align: center;
}

.empty-state text {
  color: var(--tf-muted);
  font-size: 28rpx;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
}

.loading-text {
  color: var(--tf-muted);
  font-size: 26rpx;
}

/* WeChat runtime fallback: keep OKLCH declarations above, but render with stable colors. */
page,
.container {
  background: linear-gradient(158deg, #f8fbf6, #f2faf6 54%, #fbf8f1);
  color: #233a35;
}

.fixed-top,
.top-bar,
.banner,
.user-section,
.header-banner,
.search-bar {
  background: linear-gradient(135deg, #0f7a58, #10a873 58%, #ff8f2f);
  box-shadow: 0 24rpx 58rpx rgba(23, 70, 55, 0.18);
}

.fixed-top::before,
.top-bar::after,
.banner::before,
.user-section::after {
  border-color: rgba(255, 255, 255, 0.24);
}

.fixed-top::after,
.banner-deco,
.header-banner::after {
  border-color: rgba(220, 246, 160, 0.38);
}

.banner-pattern {
  background:
    repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.25) 0 2rpx, transparent 2rpx 30rpx),
    repeating-linear-gradient(0deg, rgba(255, 255, 255, 0.16) 0 2rpx, transparent 2rpx 30rpx);
}

.search-bar,
.category-bar-wrap,
.quick-actions,
.venue-card,
.match-card,
.news-card,
.user-card.login-card,
.stats-section,
.menu-group,
.venue-info-card,
.section-card,
.action-section,
.info-card,
.remark-card,
.participants-card,
.form-card,
.booking-bar-wrapper,
.action-bar,
.submit-section,
.venue-popup,
.modal-container {
  background: #ffffff;
  border-color: #e6eee9;
  box-shadow: 0 22rpx 54rpx rgba(23, 70, 55, 0.16);
}

.search-bar {
  border-color: rgba(255, 255, 255, 0.48);
}

.venue-card::before,
.match-card::before,
.news-card::before {
  background: #e0f5dc;
}

.filter-dropdown,
.search-input-wrapper,
.time-picker,
.form-textarea,
.price-list,
.info-block,
.match-remark,
.modal-close-action,
.share-btn,
.inline-action-btn.secondary,
.remove-btn {
  background: #f6fbf7;
}

.title-text,
.banner-title,
.user-nickname,
.booking-text,
.booking-arrow,
.popup-action-text,
.popup-arrow,
.modal-share-text,
.submit-btn,
.join-btn,
.manage-btn {
  color: #fffffb;
}

.venue-name,
.popup-name,
.match-nickname,
.card-title,
.modal-title,
.section-title,
.menu-title,
.info-value,
.form-label,
.section-title,
.venue-name,
.card-title {
  color: #233a35;
}

.header-subtitle,
.banner-subtitle,
.publish-time,
.login-tip,
.card-source,
.card-date,
.modal-source,
.loading-text,
.empty-text,
.loadmore-text,
.loadmore-end-text,
.submit-tip,
.stats-label,
.version-text,
.info-label,
.price-label,
.address-text,
.info-text,
.row-text,
.remark-content,
.participant-name,
.empty-state text {
  color: #70827b;
}

.city-tag,
.tab-item.active,
.type-tag.outdoor,
.status-open,
.type-outdoor,
.popup-type.type-outdoor,
.feature-tag,
.tag-outdoor,
.category-item.active {
  background: #e8f8ee;
  color: #0f7a58;
}

.category-item.active,
.switch-btn.active,
.popup-action,
.inline-action-btn.primary,
.join-btn,
.submit-btn,
.modal-share-btn,
.empty-action,
.btn-primary,
.retry-btn {
  background: linear-gradient(135deg, #10a873, #0f7a58);
  color: #fffffb;
}

.switch-btn.active .switch-text,
.category-item.active .category-text,
.tab-item.active .switch-text {
  color: #fffffb;
}

.publish-btn {
  background: #fffffb;
}

.publish-text,
.filter-label,
.section-more,
.card-read-more,
.people-value,
.stats-value,
.info-value.link,
.booking-text,
.booking-arrow {
  color: #0f7a58;
}

.type-indoor,
.popup-type.type-indoor,
.cat-bg-match,
.cat-match,
.call-action,
.match-icon {
  background: #e2ecff;
  color: #2f63ba;
}

.cat-bg-local,
.cat-local,
.venue-icon {
  background: #e8f8ee;
}

.cat-bg-learn,
.cat-learn,
.level-tag,
.publish-icon {
  background: #fff0c8;
}

.price-value,
.price-value.evening,
.popup-price,
.level-tag,
.cat-learn .category-tag-text {
  color: #c45c18;
}

.tag,
.feature-tag {
  background: #eef9ef;
  color: #0f7a58;
}

.modal-header.cat-bg-match {
  background: linear-gradient(135deg, #2f63ba, #3979d6);
}

.modal-header.cat-bg-local {
  background: linear-gradient(135deg, #0f7a58, #10a873);
}

.modal-header.cat-bg-learn,
.booking-bar {
  background: linear-gradient(135deg, #ff8f2f, #c45c18);
}

.inline-action-btn.primary .btn-text,
.booking-bar .booking-text,
.booking-bar .booking-arrow {
  color: #fffffb;
}

.modal-icon-wrap,
.modal-close-btn {
  background: rgba(255, 255, 255, 0.2);
}
