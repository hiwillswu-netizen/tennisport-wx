/**app.wxss**/
/* 全局样式 */
page {
  --weui-BRAND: #16a34a;
  --weui-BRAND-DARK: #15803d;
  --weui-BRAND-LIGHT: #dcfce7;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  background-color: #f5f5f5;
  font-size: 28rpx;
  color: #333;
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 通用按钮样式 */
.btn-primary {
  background-color: #16a34a;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  text-align: center;
}

.btn-primary:active {
  background-color: #15803d;
}

.btn-secondary {
  background-color: #fff;
  color: #16a34a;
  border: 2rpx solid #16a34a;
  border-radius: 8rpx;
  padding: 18rpx 40rpx;
  font-size: 28rpx;
  text-align: center;
}

/* 通用卡片样式 */
.card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.tag-indoor {
  background-color: #dbeafe;
  color: #1d4ed8;
}

.tag-outdoor {
  background-color: #dcfce7;
  color: #16a34a;
}

.tag-default {
  background-color: #f3f4f6;
  color: #6b7280;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-state text {
  color: #9ca3af;
  font-size: 28rpx;
}

/* 加载状态 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
}

.loading-text {
  color: #9ca3af;
  font-size: 26rpx;
}
