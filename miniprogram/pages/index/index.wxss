/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  background:
    linear-gradient(158deg, oklch(98% 0.035 110), oklch(95% 0.04 180) 54%, oklch(98% 0.03 78));
}

.search-bar {
  position: relative;
  padding: 38rpx 24rpx 78rpx;
  background:
    linear-gradient(135deg, var(--tf-primary-deep), var(--tf-primary) 58%, var(--tf-accent));
  border-bottom-left-radius: 46rpx;
}

.search-bar::after {
  content: 'TennisFind';
  position: absolute;
  right: 28rpx;
  bottom: 18rpx;
  color: oklch(100% 0 0 / 0.18);
  font-family: var(--tf-display);
  font-size: 56rpx;
  font-weight: 850;
}

.search-input-wrap {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  padding: 18rpx 24rpx;
  background: #ffffff;
  border: 1rpx solid oklch(100% 0 0 / 0.42);
  border-radius: 999rpx;
  box-shadow: 0 18rpx 48rpx oklch(20% 0.06 166 / 0.2);
}

.search-icon {
  width: 34rpx;
  height: 34rpx;
  margin-right: 14rpx;
}

.search-input {
  flex: 1;
  color: var(--tf-ink);
  font-size: 28rpx;
}

.quick-actions {
  display: flex;
  justify-content: space-around;
  margin: -46rpx 24rpx 24rpx;
  padding: 22rpx 12rpx;
  background: #ffffff;
  border: 1rpx solid oklch(92% 0.04 150);
  border-radius: 30rpx;
  box-shadow: 0 22rpx 54rpx var(--tf-shadow);
}

.action-item {
  display: flex;
  align-items: center;
  flex-direction: column;
}

.action-icon {
  display: flex;
  width: 96rpx;
  height: 96rpx;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  border-radius: 26rpx 26rpx 8rpx 26rpx;
}

.action-icon-img {
  width: 42rpx;
  height: 42rpx;
}

.venue-icon {
  background: var(--tf-primary-soft);
}

.match-icon {
  background: oklch(93% 0.06 235);
}

.publish-icon {
  background: oklch(94% 0.08 70);
}

.profile-icon {
  background: oklch(94% 0.055 105);
}

.action-text {
  color: var(--tf-ink-soft);
  font-size: 24rpx;
  font-weight: 800;
}

.section {
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx 16rpx;
}

.section-title {
  color: var(--tf-ink);
  font-size: 34rpx;
  font-weight: 900;
}

.section-more {
  color: var(--tf-primary-deep);
  font-size: 25rpx;
  font-weight: 850;
}

.venue-list,
.match-list {
  padding: 0 24rpx;
}

.venue-card,
.match-card {
  position: relative;
  overflow: hidden;
  margin-bottom: 22rpx;
  padding: 28rpx;
  background: #ffffff;
  border: 1rpx solid oklch(92% 0.04 150);
  border-radius: 28rpx;
  box-shadow: 0 20rpx 48rpx var(--tf-shadow);
}

.venue-card:nth-child(2n),
.match-card:nth-child(2n) {
  margin-left: 30rpx;
  border-top-left-radius: 8rpx;
}

.venue-name {
  margin-bottom: 8rpx;
  color: var(--tf-ink);
  font-size: 32rpx;
  font-weight: 850;
}

.venue-address {
  margin-bottom: 12rpx;
  color: var(--tf-ink-soft);
  font-size: 26rpx;
  line-height: 1.5;
}

.venue-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.venue-price {
  font-size: 26rpx;
}

.price-label {
  color: var(--tf-muted);
}

.price-value {
  color: var(--tf-accent-deep);
  font-weight: 850;
}

.match-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.match-avatar {
  width: 72rpx;
  height: 72rpx;
  margin-right: 16rpx;
  border-radius: 50%;
}

.match-user-info {
  flex: 1;
  min-width: 0;
}

.match-nickname {
  display: block;
  color: var(--tf-ink);
  font-size: 28rpx;
  font-weight: 800;
}

.match-time {
  color: var(--tf-muted);
  font-size: 24rpx;
}

.match-status {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 850;
}

.status-open {
  color: var(--tf-primary-deep);
  background: var(--tf-primary-soft);
}

.status-closed {
  color: var(--tf-muted);
  background: oklch(93% 0.02 160);
}

.match-content {
  padding-left: 88rpx;
}

.match-info-row {
  margin-bottom: 8rpx;
  font-size: 26rpx;
}

.info-label {
  color: var(--tf-muted);
}

.info-value {
  color: var(--tf-ink);
}

.loading,
.empty-state {
  padding: 42rpx 24rpx;
  color: var(--tf-muted);
  text-align: center;
}

.publish-btn {
  width: 240rpx !important;
  margin-top: 24rpx;
}
