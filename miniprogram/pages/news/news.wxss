/* pages/news/news.wxss */
.container {
  display: flex;
  min-height: 100vh;
  flex-direction: column;
  background:
    linear-gradient(158deg, oklch(98% 0.03 110), oklch(95% 0.04 180) 54%, oklch(98% 0.03 78));
}

.banner {
  position: relative;
  display: flex;
  height: 292rpx;
  align-items: center;
  justify-content: space-between;
  overflow: hidden;
  padding: 0 38rpx;
  background:
    linear-gradient(135deg, var(--tf-primary-deep), var(--tf-primary) 54%, var(--tf-accent));
  border-bottom-left-radius: 46rpx;
  box-shadow: 0 28rpx 64rpx oklch(28% 0.07 166 / 0.22);
}

.banner::before {
  content: '';
  position: absolute;
  width: 420rpx;
  height: 120rpx;
  right: -86rpx;
  top: 42rpx;
  transform: rotate(-18deg);
  border: 2rpx solid oklch(100% 0 0 / 0.22);
  background:
    repeating-linear-gradient(90deg, oklch(100% 0 0 / 0.15) 0 2rpx, transparent 2rpx 28rpx),
    repeating-linear-gradient(0deg, oklch(100% 0 0 / 0.11) 0 2rpx, transparent 2rpx 28rpx);
}

.banner-deco {
  position: absolute;
  border-radius: 50%;
  border: 4rpx solid oklch(100% 0 0 / 0.16);
}

.deco-1 {
  width: 250rpx;
  height: 250rpx;
  right: -70rpx;
  top: -84rpx;
}

.deco-2 {
  width: 140rpx;
  height: 140rpx;
  left: 38rpx;
  bottom: -48rpx;
}

.deco-3 {
  width: 72rpx;
  height: 72rpx;
  right: 184rpx;
  top: 42rpx;
}

.banner-content {
  z-index: 1;
  flex: 1;
  min-width: 0;
}

.banner-icon-row {
  display: flex;
  align-items: center;
  margin-bottom: 14rpx;
}

.banner-icon-img {
  width: 48rpx;
  height: 48rpx;
  margin-right: 14rpx;
}

.banner-badge {
  padding: 7rpx 17rpx;
  color: oklch(100% 0 0 / 0.82);
  background: oklch(100% 0 0 / 0.14);
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 3rpx;
}

.banner-title {
  display: block;
  margin-bottom: 8rpx;
  color: oklch(99% 0.01 100);
  font-family: var(--tf-display);
  font-size: 54rpx;
  font-weight: 850;
  letter-spacing: 0;
}

.banner-subtitle {
  display: block;
  color: oklch(94% 0.04 150 / 0.8);
  font-size: 24rpx;
}

.banner-stat {
  z-index: 1;
  display: flex;
  min-width: 116rpx;
  flex-direction: column;
  align-items: center;
  padding: 18rpx 20rpx;
  background: oklch(100% 0 0 / 0.14);
  border: 1rpx solid oklch(100% 0 0 / 0.24);
  border-radius: 26rpx 26rpx 8rpx 26rpx;
}

.banner-stat-num {
  color: oklch(100% 0 0);
  font-family: var(--tf-display);
  font-size: 52rpx;
  font-weight: 850;
  line-height: 1;
}

.banner-stat-label {
  margin-top: 4rpx;
  color: oklch(96% 0.03 150 / 0.76);
  font-size: 20rpx;
}

.category-bar-wrap {
  margin: -28rpx 24rpx 0;
  padding: 8rpx;
  background: #ffffff;
  border: 1rpx solid oklch(93% 0.04 150);
  border-radius: 999rpx;
  box-shadow: 0 18rpx 44rpx var(--tf-shadow);
  z-index: 2;
}

.category-bar {
  width: 100%;
  white-space: nowrap;
}

.category-list {
  display: inline-flex;
}

.category-item {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 118rpx;
  padding: 18rpx 24rpx;
  border-radius: 999rpx;
}

.category-text {
  color: var(--tf-ink-soft);
  font-size: 26rpx;
  font-weight: 800;
  white-space: nowrap;
}

.category-item.active {
  background: var(--tf-primary-deep);
}

.category-item.active .category-text {
  color: oklch(100% 0 0);
}

.category-underline {
  display: none;
}

.news-scroll {
  flex: 1;
  height: calc(100vh - 376rpx);
}

.news-list {
  padding: 30rpx 24rpx 8rpx;
}

.news-card {
  position: relative;
  overflow: hidden;
  margin-bottom: 24rpx;
  padding: 30rpx;
  background: #ffffff;
  border: 1rpx solid oklch(92% 0.04 150);
  border-radius: 30rpx;
  box-shadow: 0 22rpx 54rpx var(--tf-shadow);
}

.news-card:nth-child(2n) {
  margin-left: 0;
  border-top-left-radius: 30rpx;
}

.news-card:nth-child(3n) {
  margin-right: 0;
  border-bottom-right-radius: 30rpx;
}

.news-card::before {
  content: '';
  position: absolute;
  width: 140rpx;
  height: 140rpx;
  right: -42rpx;
  top: -42rpx;
  transform: rotate(20deg);
  background: oklch(94% 0.06 150);
  border-radius: 34rpx;
}

.news-card-hover {
  transform: scale(0.985);
}

.card-top,
.card-title,
.card-summary,
.card-footer {
  position: relative;
  z-index: 1;
}

.card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.card-top-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.card-icon-wrap {
  display: flex;
  width: 74rpx;
  height: 74rpx;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx 22rpx 8rpx 22rpx;
  flex-shrink: 0;
}

.cat-bg-match {
  background: oklch(93% 0.06 235);
}

.cat-bg-local {
  background: var(--tf-primary-soft);
}

.cat-bg-learn {
  background: oklch(94% 0.08 70);
}

.card-icon-img {
  width: 40rpx;
  height: 40rpx;
}

.category-tag {
  flex-shrink: 0;
  padding: 6rpx 13rpx;
  border-radius: 999rpx;
}

.category-tag-text {
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
}

.cat-match {
  background: oklch(93% 0.06 235);
}

.cat-match .category-tag-text {
  color: oklch(42% 0.15 235);
}

.cat-local {
  background: var(--tf-primary-soft);
}

.cat-local .category-tag-text {
  color: var(--tf-primary-deep);
}

.cat-learn {
  background: oklch(94% 0.08 70);
}

.cat-learn .category-tag-text {
  color: var(--tf-accent-deep);
}

.card-source {
  color: var(--tf-muted);
  font-size: 23rpx;
}

.card-title {
  display: block;
  margin-bottom: 12rpx;
  color: var(--tf-ink);
  font-size: 31rpx;
  font-weight: 850;
  line-height: 1.48;
  letter-spacing: 0;
}

.card-summary {
  display: block;
  overflow: hidden;
  margin-bottom: 20rpx;
  color: var(--tf-ink-soft);
  font-size: 26rpx;
  line-height: 1.7;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid oklch(92% 0.03 150);
}

.card-date {
  color: var(--tf-muted);
  font-size: 22rpx;
}

.card-read-more {
  color: var(--tf-primary-deep);
  font-size: 24rpx;
  font-weight: 850;
}

.list-end {
  display: flex;
  justify-content: center;
  padding: 32rpx 0 20rpx;
}

.list-end-text {
  color: var(--tf-muted);
  font-size: 22rpx;
}

.safe-area-bottom {
  height: 40rpx;
}

.modal-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 100;
  display: flex;
  align-items: flex-end;
  background: oklch(18% 0.035 165 / 0.56);
}

.modal-container {
  display: flex;
  width: 100%;
  max-height: 88vh;
  flex-direction: column;
  overflow: hidden;
  background: var(--tf-surface-raised);
  border-radius: 36rpx 36rpx 0 0;
}

.modal-header {
  position: relative;
  display: flex;
  height: 166rpx;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
}

.modal-header.cat-bg-match {
  background: linear-gradient(135deg, oklch(46% 0.16 235), oklch(61% 0.18 232));
}

.modal-header.cat-bg-local {
  background: linear-gradient(135deg, var(--tf-primary-deep), var(--tf-primary));
}

.modal-header.cat-bg-learn {
  background: linear-gradient(135deg, var(--tf-accent-deep), var(--tf-accent));
}

.modal-header-deco {
  position: absolute;
  border: 4rpx solid oklch(100% 0 0 / 0.2);
  border-radius: 50%;
}

.deco-a {
  width: 200rpx;
  height: 200rpx;
  top: -60rpx;
  right: -40rpx;
}

.deco-b {
  width: 120rpx;
  height: 120rpx;
  bottom: -40rpx;
  left: 40rpx;
}

.modal-icon-wrap {
  z-index: 1;
  display: flex;
  width: 86rpx;
  height: 86rpx;
  align-items: center;
  justify-content: center;
  background: oklch(100% 0 0 / 0.2);
  border-radius: 28rpx 28rpx 10rpx 28rpx;
}

.modal-icon-img {
  width: 52rpx;
  height: 52rpx;
}

.modal-close-btn {
  position: absolute;
  top: 22rpx;
  right: 24rpx;
  z-index: 2;
  display: flex;
  width: 56rpx;
  height: 56rpx;
  align-items: center;
  justify-content: center;
  background: oklch(100% 0 0 / 0.18);
  border-radius: 50%;
}

.modal-close-icon {
  width: 25rpx;
  height: 25rpx;
}

.modal-body {
  box-sizing: border-box;
  flex: 1;
  max-height: 65vh;
  padding: 30rpx 32rpx 20rpx;
}

.modal-meta {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.modal-source {
  margin-left: 12rpx;
  color: var(--tf-muted);
  font-size: 22rpx;
}

.modal-title {
  display: block;
  margin-bottom: 24rpx;
  color: var(--tf-ink);
  font-size: 35rpx;
  font-weight: 900;
  line-height: 1.48;
}

.modal-content {
  display: block;
  color: var(--tf-ink-soft);
  font-size: 28rpx;
  line-height: 1.85;
  white-space: pre-wrap;
}

.modal-actions {
  display: flex;
  flex-shrink: 0;
  gap: 20rpx;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid oklch(92% 0.03 150);
}

.modal-close-action,
.modal-share-btn {
  display: flex;
  flex: 1;
  height: 82rpx;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  line-height: normal;
}

.modal-close-action {
  background: oklch(95% 0.025 150);
}

.modal-share-btn {
  background: linear-gradient(135deg, var(--tf-primary), var(--tf-primary-deep));
  border: none;
}

.modal-share-btn::after {
  border: none;
}

.modal-action-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 10rpx;
}

.modal-close-action-text {
  color: var(--tf-ink-soft);
  font-size: 28rpx;
  font-weight: 800;
}

.modal-share-text {
  color: oklch(100% 0 0);
  font-size: 28rpx;
  font-weight: 800;
}
