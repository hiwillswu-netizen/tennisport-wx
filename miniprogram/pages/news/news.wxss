/* pages/news/news.wxss */

.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* ═══ 顶部 Banner ═══ */
.banner {
  position: relative;
  height: 280rpx;
  background: linear-gradient(135deg, #16a34a 0%, #15803d 50%, #166534 100%);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
}

.banner-deco {
  position: absolute;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.15);
}
.deco-1 {
  width: 260rpx;
  height: 260rpx;
  top: -80rpx;
  right: -60rpx;
  border-width: 6rpx;
  border-color: rgba(255,255,255,0.12);
}
.deco-2 {
  width: 160rpx;
  height: 160rpx;
  bottom: -50rpx;
  left: 40rpx;
  border-color: rgba(255,255,255,0.1);
}
.deco-3 {
  width: 80rpx;
  height: 80rpx;
  top: 40rpx;
  right: 160rpx;
  border-color: rgba(255,255,255,0.2);
}

.banner-content {
  flex: 1;
  z-index: 1;
}

.banner-icon-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.banner-emoji {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.banner-badge {
  font-size: 20rpx;
  color: rgba(255,255,255,0.8);
  letter-spacing: 3rpx;
  background: rgba(255,255,255,0.15);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.banner-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #ffffff;
  display: block;
  margin-bottom: 10rpx;
}

.banner-subtitle {
  font-size: 24rpx;
  color: rgba(255,255,255,0.75);
  display: block;
}

.banner-stat {
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255,255,255,0.15);
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
}

.banner-stat-num {
  font-size: 52rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1;
}

.banner-stat-label {
  font-size: 20rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 4rpx;
}

/* ═══ 分类 Tab ═══ */
.category-bar-wrap {
  background-color: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.category-bar {
  white-space: nowrap;
  width: 100%;
}

.category-list {
  display: inline-flex;
  padding: 0 16rpx;
}

.category-item {
  position: relative;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 28rpx 20rpx;
  margin: 0 4rpx;
}

.category-text {
  font-size: 28rpx;
  color: #666666;
  white-space: nowrap;
}

.category-item.active .category-text {
  color: #16a34a;
  font-weight: 600;
}

.category-underline {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 36rpx;
  height: 4rpx;
  background-color: #16a34a;
  border-radius: 2rpx;
}

/* ═══ 列表滚动区 ═══ */
.news-scroll {
  flex: 1;
  height: calc(100vh - 476rpx);
}

.news-list {
  padding: 16rpx 0 8rpx;
}

/* ═══ 资讯卡片 ═══ */
.news-card {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  background-color: #ffffff;
  margin: 12rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.news-card-hover {
  background-color: #f9fafb;
  transform: scale(0.99);
}

.card-cover {
  width: 100rpx;
  min-height: 100rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  align-self: stretch;
}

.card-emoji {
  font-size: 44rpx;
}

.card-body {
  flex: 1;
  padding: 20rpx 20rpx 16rpx;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.card-meta {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

/* 分类标签通用 */
.category-tag {
  border-radius: 6rpx;
  padding: 4rpx 12rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.category-tag-text {
  font-size: 20rpx;
  font-weight: 600;
}

/* 赛事 - 蓝色 */
.cat-match {
  background-color: #dbeafe;
}
.cat-match .category-tag-text {
  color: #1d4ed8;
}

/* 本地 - 绿色 */
.cat-local {
  background-color: #dcfce7;
}
.cat-local .category-tag-text {
  color: #16a34a;
}

/* 教学 - 橙色 */
.cat-learn {
  background-color: #fef3c7;
}
.cat-learn .category-tag-text {
  color: #d97706;
}

.card-source {
  font-size: 22rpx;
  color: #999999;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.5;
  margin-bottom: 8rpx;
  overflow: hidden;
}

.card-summary {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
  margin-bottom: 12rpx;
  overflow: hidden;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
}

.card-date {
  font-size: 22rpx;
  color: #aaaaaa;
}

.card-arrow {
  font-size: 36rpx;
  color: #cccccc;
  font-weight: 300;
  line-height: 1;
}

/* ═══ 列表底部 ═══ */
.list-end {
  display: flex;
  justify-content: center;
  padding: 32rpx 0 20rpx;
}

.list-end-text {
  font-size: 22rpx;
  color: #cccccc;
}

.safe-area-bottom {
  height: 40rpx;
}

/* ═══ 详情弹窗 ═══ */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.55);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.modal-container {
  width: 100%;
  max-height: 88vh;
  background-color: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  position: relative;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
}

.modal-header-deco {
  position: absolute;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.2);
}
.deco-a {
  width: 200rpx;
  height: 200rpx;
  top: -60rpx;
  right: -40rpx;
}
.deco-b {
  width: 120rpx;
  height: 120rpx;
  bottom: -40rpx;
  left: 40rpx;
  border-color: rgba(255,255,255,0.15);
}

.modal-emoji-wrap {
  z-index: 1;
}

.modal-emoji {
  font-size: 72rpx;
}

.modal-close-btn {
  position: absolute;
  top: 20rpx;
  right: 24rpx;
  width: 56rpx;
  height: 56rpx;
  background: rgba(0,0,0,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.modal-close-icon {
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
  font-weight: 500;
}

.modal-body {
  flex: 1;
  padding: 28rpx 32rpx 20rpx;
  max-height: 65vh;
  box-sizing: border-box;
}

.modal-meta {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.modal-source {
  font-size: 22rpx;
  color: #999999;
  margin-left: 12rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.5;
  display: block;
  margin-bottom: 24rpx;
}

.modal-content {
  font-size: 28rpx;
  color: #444444;
  line-height: 1.8;
  display: block;
  white-space: pre-wrap;
}

.modal-actions {
  display: flex;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0f0f0;
  gap: 20rpx;
  flex-shrink: 0;
}

.modal-close-action {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  border: 2rpx solid #e5e5e5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-close-action-text {
  font-size: 28rpx;
  color: #666666;
}

.modal-share-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  background-color: #16a34a;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  line-height: normal;
}

.modal-share-btn::after {
  border: none;
}

.modal-share-text {
  font-size: 28rpx;
  color: #ffffff;
}
