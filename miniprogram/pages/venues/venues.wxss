/* pages/venues/venues.wxss */
page {
  overflow-x: hidden;
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f5f5f5;
  position: relative;
  overflow-x: hidden;
  width: 100%;
}

/* 固定顶部区域 */
.fixed-top {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background-color: #fff;
}

/* 顶部占位，防止内容被固定栏遮挡 */
.fixed-top-placeholder {
  height: 260rpx;
}

/* 头部区域 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 32rpx 32rpx 20rpx;
  background-color: #fff;
}

.header-left {
  flex: 1;
}

.header-title {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.location-icon {
  font-size: 36rpx;
  margin-right: 8rpx;
}

.title-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.header-subtitle {
  font-size: 24rpx;
  color: #999;
}

.city-tag {
  padding: 10rpx 20rpx;
  background-color: #dcfce7;
  color: #16a34a;
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 500;
}

/* 搜索栏和筛选下拉 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  gap: 12rpx;
}

/* 筛选下拉选择器 */
.filter-picker {
  flex-shrink: 0;
}

.filter-dropdown {
  display: flex;
  align-items: center;
  padding: 14rpx 16rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
}

.filter-label {
  font-size: 24rpx;
  color: #333;
  max-width: 80rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dropdown-arrow {
  font-size: 16rpx;
  color: #999;
  margin-left: 4rpx;
}

.search-input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 14rpx 16rpx;
  min-width: 0;
  transition: all 0.2s;
}

.search-input-wrapper.focused {
  background-color: #fff;
  box-shadow: 0 0 0 2rpx #16a34a;
}

.search-icon {
  font-size: 26rpx;
  margin-right: 8rpx;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  min-width: 0;
}

.search-placeholder {
  color: #999;
}

.clear-btn {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #ccc;
  border-radius: 50%;
  margin-left: 8rpx;
  flex-shrink: 0;
}

.clear-icon {
  font-size: 18rpx;
  color: #fff;
}

/* 结果统计 */
.result-info {
  padding: 20rpx 32rpx 8rpx;
}

.result-count {
  font-size: 24rpx;
  color: #999;
}

/* 加载状态 */
.loading-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e5e5e5;
  border-top-color: #16a34a;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.empty-action {
  padding: 16rpx 40rpx;
  background-color: #16a34a;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

/* 场馆滚动区域 */
.venue-scroll {
  flex: 1;
  height: calc(100vh - 420rpx);
}

/* 场馆列表 */
.venue-list {
  padding: 0 24rpx 120rpx;
}

/* 场馆卡片 */
.venue-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #f0f0f0;
  transition: all 0.15s;
}

.venue-card-hover {
  transform: scale(0.98);
  background-color: #fafafa;
}

.venue-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.venue-name {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.4;
  margin-right: 16rpx;
}

.venue-type {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.type-indoor {
  background-color: #dbeafe;
  color: #2563eb;
}

.type-outdoor {
  background-color: #dcfce7;
  color: #16a34a;
}

.venue-address {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.venue-address .icon {
  font-size: 24rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.address-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.venue-info-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.info-item {
  display: flex;
  align-items: center;
}

.info-item .icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.info-text {
  font-size: 24rpx;
  color: #999;
}

.venue-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.venue-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  padding: 6rpx 14rpx;
  background-color: #f5f5f5;
  color: #666;
  font-size: 22rpx;
  border-radius: 6rpx;
}

.venue-price {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.price-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #f97316;
}

.venue-booking {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
}

.booking-text {
  font-size: 24rpx;
  color: #3b82f6;
}

.booking-arrow {
  font-size: 24rpx;
  color: #3b82f6;
  margin-left: 8rpx;
}

/* 加载更多 */
.loadmore {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
}

.loadmore-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #e5e5e5;
  border-top-color: #16a34a;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-right: 16rpx;
}

.loadmore-text {
  font-size: 24rpx;
  color: #999;
}

.loadmore-end {
  text-align: center;
  padding: 32rpx 0 60rpx;
}

.loadmore-end-text {
  font-size: 24rpx;
  color: #ccc;
}

/* 地图容器 */
.map-container {
  flex: 1;
  height: calc(100vh - 380rpx);
  position: relative;
}

.venue-map {
  width: 100%;
  height: 100%;
}

/* 我的位置按钮 */
.my-location-btn {
  position: absolute;
  right: 32rpx;
  bottom: 140rpx;
  width: 88rpx;
  height: 88rpx;
  background-color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
  z-index: 10;
}

.location-btn-icon {
  font-size: 40rpx;
}

/* 球馆信息弹窗 */
.venue-popup {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 200rpx;
  background-color: #fff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.15);
  transform: translateY(120%);
  transition: transform 0.3s ease;
  z-index: 20;
  overflow: hidden;
}

.venue-popup.show {
  transform: translateY(0);
}

.popup-close {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #999;
  background-color: #f5f5f5;
  border-radius: 50%;
  z-index: 1;
}

.popup-content {
  padding: 28rpx;
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
  padding-right: 48rpx;
}

.popup-name {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.4;
}

.popup-type {
  flex-shrink: 0;
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  margin-left: 16rpx;
}

.popup-type.type-indoor {
  background-color: #dbeafe;
  color: #2563eb;
}

.popup-type.type-outdoor {
  background-color: #dcfce7;
  color: #16a34a;
}

.popup-address {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  color: #666;
}

.popup-icon {
  margin-right: 8rpx;
  flex-shrink: 0;
}

.popup-info {
  display: flex;
  gap: 32rpx;
  margin-bottom: 16rpx;
}

.popup-price,
.popup-hours {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
}

.popup-price {
  color: #f97316;
  font-weight: 500;
}

.popup-action {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  margin-top: 8rpx;
  background-color: #16a34a;
  border-radius: 12rpx;
}

.popup-action-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

.popup-arrow {
  font-size: 28rpx;
  color: #fff;
  margin-left: 8rpx;
}

/* 视图切换按钮 */
.view-switcher {
  position: fixed;
  bottom: calc(env(safe-area-inset-bottom) + 20rpx);
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  background-color: #fff;
  border-radius: 48rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.15);
  overflow: hidden;
  z-index: 100;
}

.switch-btn {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  transition: all 0.2s;
}

.switch-btn.active {
  background-color: #16a34a;
}

.switch-btn.active .switch-icon,
.switch-btn.active .switch-text {
  color: #fff;
}

.switch-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
  color: #666;
}

.switch-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #666;
}

/* 筛选抽屉 */
.filter-drawer {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  visibility: hidden;
}

.filter-drawer.open {
  visibility: visible;
}

.filter-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  opacity: 0;
  transition: opacity 0.3s;
}

.filter-drawer.open .filter-mask {
  opacity: 1;
}

.filter-content {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 80%;
  max-width: 600rpx;
  background-color: #fff;
  transform: translateX(100%);
  transition: transform 0.3s;
  display: flex;
  flex-direction: column;
}

.filter-drawer.open .filter-content {
  transform: translateX(0);
}

.filter-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.filter-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.filter-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #999;
}

.filter-section {
  padding: 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.filter-section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-option {
  padding: 16rpx 32rpx;
  background-color: #f5f5f5;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.2s;
}

.filter-option.active {
  background-color: #dcfce7;
  color: #16a34a;
  font-weight: 500;
}

.filter-actions {
  margin-top: auto;
  display: flex;
  padding: 32rpx;
  gap: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.filter-reset {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  background-color: #f5f5f5;
  border-radius: 48rpx;
  font-size: 28rpx;
  color: #666;
}

.filter-confirm {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  background-color: #16a34a;
  border-radius: 48rpx;
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}
