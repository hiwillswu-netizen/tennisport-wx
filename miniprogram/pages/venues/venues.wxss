/* pages/venues/venues.wxss */
page {
  overflow-x: hidden;
  background: var(--tf-surface);
}

.container {
  position: relative;
  width: 100%;
  min-height: 100vh;
  overflow-x: hidden;
  background:
    linear-gradient(160deg, oklch(98% 0.035 112), oklch(95% 0.045 172) 48%, oklch(98% 0.03 74));
}

.fixed-top {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  overflow: hidden;
  background:
    linear-gradient(135deg, oklch(47% 0.16 166), oklch(35% 0.13 174) 62%, oklch(66% 0.21 42));
  border-bottom-left-radius: 44rpx;
  border-bottom-right-radius: 12rpx;
  box-shadow: 0 30rpx 70rpx oklch(28% 0.07 165 / 0.22);
  padding-bottom: 28rpx;
}

.fixed-top::before {
  content: '';
  position: absolute;
  width: 460rpx;
  height: 220rpx;
  right: -120rpx;
  top: -46rpx;
  transform: rotate(-18deg);
  border: 2rpx solid oklch(100% 0 0 / 0.22);
  background:
    repeating-linear-gradient(90deg, oklch(100% 0 0 / 0.18) 0 2rpx, transparent 2rpx 30rpx),
    repeating-linear-gradient(0deg, oklch(100% 0 0 / 0.12) 0 2rpx, transparent 2rpx 30rpx);
}

.fixed-top::after {
  content: '';
  position: absolute;
  width: 160rpx;
  height: 160rpx;
  right: 36rpx;
  bottom: 24rpx;
  border-radius: 50%;
  border: 4rpx solid oklch(88% 0.17 116 / 0.36);
  opacity: 0.7;
}

.fixed-top-placeholder {
  height: 338rpx;
}

.header {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 36rpx 34rpx 22rpx;
}

.header-left {
  flex: 1;
  min-width: 0;
}

.header-title {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.location-icon {
  width: 46rpx;
  height: 46rpx;
  margin-right: 10rpx;
}

.title-text {
  color: oklch(99% 0.015 112);
  font-family: var(--tf-display);
  font-size: 46rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.header-subtitle {
  color: #e8fff2;
  color: oklch(93% 0.05 150 / 0.82);
  font-size: 24rpx;
  font-weight: 700;
  text-shadow: 0 2rpx 8rpx rgba(15, 84, 62, 0.38);
}

.city-tag {
  padding: 11rpx 22rpx;
  color: oklch(31% 0.12 166);
  background: oklch(96% 0.08 130);
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 800;
  box-shadow: 0 10rpx 26rpx oklch(20% 0.06 166 / 0.18);
}

.search-bar {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 0 24rpx;
  padding: 18rpx;
  background: #ffffff;
  border: 1rpx solid oklch(100% 0 0 / 0.46);
  border-radius: 28rpx;
  box-shadow: 0 18rpx 50rpx oklch(20% 0.05 166 / 0.2);
}

.filter-picker {
  flex-shrink: 0;
}

.filter-dropdown {
  display: flex;
  align-items: center;
  height: 58rpx;
  padding: 0 18rpx;
  background: oklch(94% 0.06 150);
  border-radius: 999rpx;
  box-sizing: border-box;
}

.filter-label {
  max-width: 96rpx;
  overflow: hidden;
  color: var(--tf-primary-deep);
  font-size: 23rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dropdown-arrow {
  margin-left: 6rpx;
  color: oklch(46% 0.11 166);
  font-size: 16rpx;
}

.search-input-wrapper {
  display: flex;
  flex: 1;
  min-width: 250rpx;
  height: 58rpx;
  align-items: center;
  padding: 0 18rpx;
  background: oklch(98% 0.015 105);
  border: 2rpx solid transparent;
  border-radius: 999rpx;
  box-sizing: border-box;
}

.search-input-wrapper.focused {
  background: #ffffff;
  border-color: var(--tf-accent);
  box-shadow: 0 0 0 6rpx oklch(72% 0.2 42 / 0.16);
}

.search-icon {
  margin-right: 10rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  color: var(--tf-ink);
  font-size: 26rpx;
}

.search-placeholder {
  color: var(--tf-muted);
}

.clear-btn {
  display: flex;
  width: 36rpx;
  height: 36rpx;
  align-items: center;
  justify-content: center;
  margin-left: 8rpx;
  background: oklch(90% 0.03 160);
  border-radius: 50%;
}

.clear-icon {
  width: 22rpx;
  height: 22rpx;
}

.loading-wrapper,
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 40rpx;
}

.loading-spinner,
.loadmore-spinner {
  border: 4rpx solid oklch(89% 0.04 155);
  border-top-color: var(--tf-accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text,
.empty-text,
.loadmore-text,
.loadmore-end-text {
  color: var(--tf-muted);
  font-size: 26rpx;
}

.empty-action {
  margin-top: 30rpx;
  padding: 18rpx 42rpx;
  color: oklch(100% 0 0);
  background: linear-gradient(135deg, var(--tf-primary), var(--tf-primary-deep));
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 800;
  box-shadow: 0 16rpx 38rpx var(--tf-shadow);
}

.venue-scroll {
  flex: 1;
  height: calc(100vh - 304rpx);
}

.venue-list {
  padding: 10rpx 24rpx 270rpx;
}

.venue-card {
  position: relative;
  overflow: hidden;
  margin-bottom: 26rpx;
  padding: 30rpx;
  background: #ffffff;
  border: 1rpx solid oklch(92% 0.04 150);
  border-radius: 28rpx;
  box-shadow: 0 24rpx 56rpx var(--tf-shadow);
  transition: transform 0.15s ease;
}

.venue-card:nth-child(2n) {
  margin-left: 0;
  border-top-left-radius: 28rpx;
}

.venue-card:nth-child(3n) {
  margin-right: 0;
  border-bottom-right-radius: 28rpx;
}

.venue-card::before {
  content: '';
  position: absolute;
  width: 160rpx;
  height: 160rpx;
  right: -56rpx;
  top: -52rpx;
  transform: rotate(18deg);
  background: oklch(92% 0.08 128);
  border-radius: 32rpx;
}

.venue-card-hover {
  transform: scale(0.985) translateY(2rpx);
}

.venue-header,
.venue-footer,
.venue-info-row,
.venue-booking {
  position: relative;
  z-index: 1;
}

.venue-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.venue-name {
  flex: 1;
  margin-right: 16rpx;
  color: var(--tf-ink);
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.35;
}

.venue-type,
.popup-type {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.type-indoor,
.popup-type.type-indoor {
  color: oklch(40% 0.15 235);
  background: oklch(93% 0.06 235);
}

.type-outdoor,
.popup-type.type-outdoor {
  color: var(--tf-primary-deep);
  background: var(--tf-primary-soft);
}

.venue-address,
.info-item,
.popup-address,
.popup-price,
.popup-hours {
  display: flex;
  align-items: center;
}

.venue-address {
  position: relative;
  z-index: 1;
  align-items: flex-start;
  margin-bottom: 14rpx;
}

.venue-address .icon,
.info-item .icon,
.popup-icon {
  margin-right: 10rpx;
}

.address-text,
.info-text,
.popup-address {
  color: var(--tf-ink-soft);
  font-size: 25rpx;
  line-height: 1.55;
}

.venue-info-row {
  display: flex;
  flex-wrap: wrap;
  gap: 22rpx;
  margin-bottom: 18rpx;
}

.venue-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.venue-tags {
  display: flex;
  flex: 1;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  padding: 8rpx 14rpx;
  color: var(--tf-primary-deep);
  background: oklch(94% 0.05 145);
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.venue-price {
  margin-left: 16rpx;
}

.price-value {
  color: var(--tf-accent-deep);
  font-size: 28rpx;
  font-weight: 900;
}

.venue-booking {
  display: flex;
  align-items: center;
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  color: #c45c18;
  background: #fff3dc;
  border-radius: 18rpx;
}

.booking-text,
.booking-arrow {
  color: #c45c18;
  font-size: 24rpx;
  font-weight: 800;
}

.booking-arrow {
  margin-left: 8rpx;
}

.loadmore {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
}

.loadmore-spinner {
  width: 32rpx;
  height: 32rpx;
  margin-right: 16rpx;
}

.loadmore-end {
  text-align: center;
  padding: 34rpx 0 70rpx;
}

.map-container {
  position: relative;
  flex: 1;
  height: calc(100vh - 304rpx);
  overflow: hidden;
  border-top-left-radius: 36rpx;
}

.venue-map {
  width: 100%;
  height: 100%;
}

.my-location-btn {
  position: absolute;
  right: 30rpx;
  bottom: 142rpx;
  z-index: 10;
  display: flex;
  width: 92rpx;
  height: 92rpx;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  border: 1rpx solid oklch(90% 0.04 155);
  border-radius: 50%;
  box-shadow: 0 18rpx 42rpx var(--tf-shadow);
}

.location-btn-icon {
  width: 42rpx;
  height: 42rpx;
}

.venue-popup {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 198rpx;
  z-index: 20;
  overflow: hidden;
  background: #ffffff;
  border: 1rpx solid oklch(91% 0.04 150);
  border-radius: 30rpx;
  box-shadow: 0 30rpx 70rpx oklch(20% 0.05 166 / 0.24);
  transform: translateY(120%);
  transition: transform 0.3s ease;
}

.venue-popup.show {
  transform: translateY(0);
}

.popup-close {
  position: absolute;
  top: 18rpx;
  right: 18rpx;
  z-index: 1;
  display: flex;
  width: 50rpx;
  height: 50rpx;
  align-items: center;
  justify-content: center;
  background: oklch(94% 0.03 150);
  border-radius: 50%;
}

.popup-close-icon {
  width: 24rpx;
  height: 24rpx;
}

.popup-content {
  padding: 30rpx;
}

.popup-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding-right: 54rpx;
}

.popup-name {
  flex: 1;
  color: var(--tf-ink);
  font-size: 33rpx;
  font-weight: 900;
  line-height: 1.35;
}

.popup-info {
  display: flex;
  gap: 28rpx;
  margin: 14rpx 0 18rpx;
}

.popup-price {
  color: var(--tf-accent-deep);
  font-weight: 800;
}

.popup-action {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx;
  background: linear-gradient(135deg, var(--tf-primary), var(--tf-primary-deep));
  border-radius: 999rpx;
}

.popup-action-text,
.popup-arrow {
  color: oklch(100% 0 0);
  font-size: 28rpx;
  font-weight: 800;
}

.popup-arrow {
  margin-left: 8rpx;
}

.view-switcher {
  position: fixed;
  bottom: calc(env(safe-area-inset-bottom) + 20rpx);
  left: 50%;
  z-index: 100;
  display: flex;
  padding: 8rpx;
  background: #ffffff;
  border: 1rpx solid oklch(92% 0.04 150);
  border-radius: 999rpx;
  box-shadow: 0 18rpx 50rpx var(--tf-shadow);
  transform: translateX(-50%);
}

.switch-btn {
  display: flex;
  align-items: center;
  min-width: 128rpx;
  justify-content: center;
  padding: 18rpx 24rpx;
  border-radius: 999rpx;
}

.switch-btn.active {
  background: var(--tf-primary-deep);
}

.switch-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
}

.switch-text {
  color: #5f716b;
  font-size: 26rpx;
  font-weight: 800;
}

.switch-btn.active .switch-text {
  color: oklch(100% 0 0);
}

.switch-btn.active .switch-text,
.switch-text-active {
  color: #fffffb;
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.18);
}
