/* pages/venues/venues.wxss */
.filter-bar {
  display: flex;
  background-color: #fff;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 8rpx;
  margin: 0 8rpx;
}

.filter-item.active {
  background-color: #16a34a;
  color: #fff;
}

.district-filter {
  background-color: #fff;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.district-scroll {
  white-space: nowrap;
  padding: 0 20rpx;
}

.district-item {
  display: inline-block;
  padding: 12rpx 24rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  color: #666;
  background-color: #f5f5f5;
  border-radius: 24rpx;
}

.district-item.active {
  background-color: #dcfce7;
  color: #16a34a;
}

.venue-scroll {
  flex: 1;
  height: calc(100vh - 240rpx);
}

.venue-card {
  display: flex;
  justify-content: space-between;
  background-color: #fff;
  margin: 20rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.venue-main {
  flex: 1;
  margin-right: 20rpx;
}

.venue-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.venue-address {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: flex;
  align-items: flex-start;
}

.address-icon {
  margin-right: 8rpx;
}

.venue-meta {
  display: flex;
  flex-wrap: wrap;
}

.venue-tags {
  display: flex;
  flex-wrap: wrap;
}

.venue-extra {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: center;
}

.venue-price {
  text-align: right;
  margin-bottom: 12rpx;
}

.price-value {
  display: block;
  font-size: 28rpx;
  color: #ea580c;
  font-weight: 600;
}

.price-label {
  font-size: 22rpx;
  color: #999;
}

.venue-courts {
  text-align: right;
}

.courts-value {
  display: block;
  font-size: 32rpx;
  color: #16a34a;
  font-weight: 600;
}

.courts-label {
  font-size: 22rpx;
  color: #999;
}

.load-more, .no-more {
  padding: 32rpx;
  text-align: center;
}

.no-more text {
  color: #ccc;
  font-size: 24rpx;
}
