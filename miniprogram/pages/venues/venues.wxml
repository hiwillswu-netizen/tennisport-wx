<!--pages/venues/venues.wxml-->
<view class="container">
  <!-- 固定顶部区域 -->
  <view class="fixed-top">
    <!-- 头部标题区域 -->
    <view class="header">
      <view class="header-left">
        <view class="header-title">
          <image class="location-icon" src="/images/tennis-ball.svg" mode="aspectFit"/>
          <text class="title-text">Find杭州网球</text>
        </view>
        <view class="header-subtitle">共 {{totalCount}} 个场馆 · 覆盖杭州主城区</view>
      </view>
      <view class="city-tag">杭州</view>
    </view>

    <!-- 搜索栏和筛选下拉 -->
    <view class="search-bar">
      <!-- 区域下拉 -->
      <picker class="filter-picker" mode="selector" range="{{districtOptions}}" value="{{districtIndex}}" bindchange="onDistrictChange">
        <view class="filter-dropdown">
          <text class="filter-label">{{currentDistrict || '杭州'}}</text>
          <text class="dropdown-arrow">▼</text>
        </view>
      </picker>
      <!-- 场地类型下拉 -->
      <picker class="filter-picker" mode="selector" range="{{typeOptions}}" value="{{typeIndex}}" bindchange="onTypeChange">
        <view class="filter-dropdown">
          <text class="filter-label">{{currentType || '场地'}}</text>
          <text class="dropdown-arrow">▼</text>
        </view>
      </picker>
      <!-- 是否可预定下拉 -->
      <picker class="filter-picker" mode="selector" range="{{bookableOptions}}" value="{{bookableIndex}}" bindchange="onBookableChange">
        <view class="filter-dropdown">
          <text class="filter-label">{{currentBookable || '预定'}}</text>
          <text class="dropdown-arrow">▼</text>
        </view>
      </picker>
      <!-- 搜索框 -->
      <view class="search-input-wrapper {{searchFocused ? 'focused' : ''}}">
        <image class="search-icon icon-img" src="/images/lucide/search.svg" mode="aspectFit"/>
        <input 
          class="search-input"
          placeholder="搜索场馆..."
          placeholder-class="search-placeholder"
          value="{{searchValue}}"
          bindinput="onSearchInput"
          bindconfirm="onSearch"
          bindfocus="onSearchFocus"
          bindblur="onSearchBlur"
        />
        <view wx:if="{{searchValue}}" class="clear-btn" bindtap="onClearSearch">
          <image class="clear-icon icon-img" src="/images/lucide/x.svg" mode="aspectFit"/>
        </view>
      </view>
    </view>
  </view>
  <!-- 顶部占位 -->
  <view class="fixed-top-placeholder"></view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-wrapper">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{venues.length === 0}}" class="empty-state">
    <image class="empty-icon-img" src="/images/lucide/circle-dot.svg" mode="aspectFit"/>
    <text class="empty-text">暂无符合条件的场馆</text>
    <view class="empty-action" bindtap="resetFilters">重置筛选条件</view>
  </view>

  <!-- 列表视图 -->
  <scroll-view 
    wx:elif="{{viewMode === 'list'}}" 
    class="venue-scroll" 
    scroll-y 
    enhanced
    bindscrolltolower="loadMore"
    refresher-enabled
    bindrefresherrefresh="onRefresh"
    refresher-triggered="{{refreshing}}"
  >
    <view class="venue-list">
      <view 
        class="venue-card" 
        wx:for="{{venues}}" 
        wx:key="_id"
        bindtap="goToDetail"
        data-id="{{item._id}}"
        hover-class="venue-card-hover"
      >
        <view class="venue-header">
          <view class="venue-name">{{item.name}}</view>
          <view class="venue-type {{item.type === '室内' ? 'type-indoor' : 'type-outdoor'}}">{{item.type}}</view>
        </view>
        
        <view class="venue-address">
          <image class="icon icon-img" src="/images/lucide/map-pin.svg" mode="aspectFit"/>
          <text class="address-text">{{item.address}}</text>
        </view>
        
        <view class="venue-info-row">
          <view class="info-item">
            <image class="icon icon-img" src="/images/lucide/clock.svg" mode="aspectFit"/>
            <text class="info-text">{{item.hours || '06:00-22:00'}}</text>
          </view>
          <view class="info-item" wx:if="{{item.phone}}">
            <image class="icon icon-img" src="/images/lucide/phone.svg" mode="aspectFit"/>
            <text class="info-text">{{item.phone}}</text>
          </view>
        </view>
        
        <view class="venue-footer">
          <view class="venue-tags">
            <view class="tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" wx:if="{{index < 3}}">{{tag}}</view>
            <view class="tag" wx:if="{{!item.tags || item.tags.length === 0}}">{{item.courtType || '硬地'}}</view>
          </view>
          <view class="venue-price" wx:if="{{item.priceWeekday}}">
            <text class="price-value">{{item.priceWeekday}}</text>
          </view>
        </view>
        
        <view class="venue-booking" wx:if="{{item.bookingMiniProgram}}">
          <text class="booking-text">可预订: {{item.bookingMiniProgram}}</text>
          <text class="booking-arrow">→</text>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view class="loadmore" wx:if="{{hasMore}}">
      <view class="loadmore-spinner"></view>
      <text class="loadmore-text">加载更多...</text>
    </view>
    <view class="loadmore-end" wx:if="{{!hasMore && venues.length > 0}}">
      <text class="loadmore-end-text">已经到底了</text>
    </view>
  </scroll-view>

  <!-- 地图视图 -->
  <view wx:elif="{{viewMode === 'map'}}" class="map-container">
    <map 
      id="venueMap"
      class="venue-map"
      longitude="{{mapCenter.longitude}}"
      latitude="{{mapCenter.latitude}}"
      scale="{{mapScale}}"
      markers="{{markers}}"
      show-location
      enable-scroll
      enable-zoom
      bindmarkertap="onMarkerTap"
      bindcallouttap="onCalloutTap"
    />
    <!-- 我的位置按钮 -->
    <view class="my-location-btn" bindtap="moveToMyLocation">
      <image class="location-btn-icon" src="/images/lucide/locate-fixed.svg" mode="aspectFit"/>
    </view>
    
    <!-- 球馆信息弹窗 -->
    <view class="venue-popup {{selectedVenue ? 'show' : ''}}" wx:if="{{selectedVenue}}">
      <view class="popup-close" bindtap="closeVenuePopup">
        <image class="popup-close-icon" src="/images/lucide/x.svg" mode="aspectFit"/>
      </view>
      <view class="popup-content" bindtap="goToDetailFromPopup">
        <view class="popup-header">
          <view class="popup-name">{{selectedVenue.name}}</view>
          <view class="popup-type {{selectedVenue.type === '室内' ? 'type-indoor' : 'type-outdoor'}}">{{selectedVenue.type}}</view>
        </view>
        <view class="popup-address">
          <image class="popup-icon icon-img" src="/images/lucide/map-pin.svg" mode="aspectFit"/>
          <text>{{selectedVenue.address}}</text>
        </view>
        <view class="popup-info">
          <view class="popup-price" wx:if="{{selectedVenue.priceWeekday}}">
            <image class="popup-icon icon-img" src="/images/lucide/dollar-sign.svg" mode="aspectFit"/>
            <text>{{selectedVenue.priceWeekday}}</text>
          </view>
          <view class="popup-hours" wx:if="{{selectedVenue.hours}}">
            <image class="popup-icon icon-img" src="/images/lucide/clock.svg" mode="aspectFit"/>
            <text>{{selectedVenue.hours}}</text>
          </view>
        </view>
        <view class="popup-action">
          <text class="popup-action-text">点击查看详情</text>
          <text class="popup-arrow">→</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 视图切换按钮 -->
  <view class="view-switcher">
    <view 
      class="switch-btn {{viewMode === 'list' ? 'active' : ''}}" 
      bindtap="switchViewMode"
      data-mode="list"
    >
      <image wx:if="{{viewMode === 'list'}}" class="switch-icon" src="/images/lucide/list-white.svg" mode="aspectFit"/>
      <image wx:else class="switch-icon" src="/images/lucide/list.svg" mode="aspectFit"/>
      <text class="switch-text {{viewMode === 'list' ? 'switch-text-active' : ''}}">列表</text>
    </view>
    <view 
      class="switch-btn {{viewMode === 'map' ? 'active' : ''}}" 
      bindtap="switchViewMode"
      data-mode="map"
    >
      <image wx:if="{{viewMode === 'map'}}" class="switch-icon" src="/images/lucide/map-white.svg" mode="aspectFit"/>
      <image wx:else class="switch-icon" src="/images/lucide/map.svg" mode="aspectFit"/>
      <text class="switch-text {{viewMode === 'map' ? 'switch-text-active' : ''}}">地图</text>
    </view>
  </view>
</view>
