/* pages/match-detail/match-detail.wxss */
.container {
  min-height: 100vh;
  padding-bottom: 150rpx;
  background:
    linear-gradient(158deg, oklch(98% 0.035 110), oklch(95% 0.04 180) 54%, oklch(98% 0.03 78));
}

.user-section {
  position: relative;
  display: flex;
  align-items: center;
  overflow: hidden;
  padding: 40rpx 28rpx 42rpx;
  background:
    linear-gradient(135deg, var(--tf-primary-deep), var(--tf-primary) 58%, var(--tf-accent));
  border-bottom-left-radius: 46rpx;
}

.user-section::after {
  content: '';
  position: absolute;
  width: 330rpx;
  height: 110rpx;
  right: -70rpx;
  bottom: 22rpx;
  transform: rotate(-18deg);
  border: 2rpx solid oklch(100% 0 0 / 0.22);
}

.user-avatar {
  z-index: 1;
  width: 100rpx;
  height: 100rpx;
  margin-right: 22rpx;
  border: 4rpx solid oklch(100% 0 0 / 0.42);
  border-radius: 50%;
}

.user-info {
  z-index: 1;
  flex: 1;
  min-width: 0;
}

.user-nickname {
  display: block;
  margin-bottom: 8rpx;
  color: #fffffb;
  font-size: 33rpx;
  font-weight: 850;
  text-shadow: 0 2rpx 8rpx rgba(15, 84, 62, 0.36);
}

.publish-time {
  color: #e8fff2;
  font-size: 24rpx;
  font-weight: 700;
  text-shadow: 0 2rpx 8rpx rgba(15, 84, 62, 0.32);
}

.match-status {
  z-index: 1;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  font-size: 25rpx;
  font-weight: 900;
}

.status-open {
  color: var(--tf-primary-deep);
  background: oklch(96% 0.08 130);
}

.status-closed {
  color: var(--tf-ink-soft);
  background: oklch(93% 0.02 160);
}

.info-card,
.remark-card,
.participants-card {
  overflow: hidden;
  margin: 22rpx 24rpx 24rpx;
  background: #ffffff;
  border: 1rpx solid oklch(92% 0.04 150);
  border-radius: 30rpx;
  box-shadow: 0 22rpx 56rpx var(--tf-shadow);
}

.remark-card,
.participants-card {
  margin-top: 0;
  padding: 28rpx 30rpx;
}

.participants-card {
  margin-left: 24rpx;
  border-top-left-radius: 30rpx;
}

.info-item {
  display: flex;
  align-items: center;
  padding: 26rpx 30rpx;
  border-bottom: 1rpx solid oklch(92% 0.03 150);
}

.info-item:last-child {
  border-bottom: none;
}

.info-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 20rpx;
}

.info-content {
  flex: 1;
}

.info-label {
  display: block;
  margin-bottom: 6rpx;
  color: var(--tf-muted);
  font-size: 24rpx;
}

.info-value {
  color: var(--tf-ink);
  font-size: 30rpx;
  font-weight: 750;
}

.info-value.link {
  color: var(--tf-primary-deep);
}

.card-title {
  margin-bottom: 16rpx;
  color: var(--tf-ink);
  font-size: 30rpx;
  font-weight: 900;
}

.remark-content {
  color: var(--tf-ink-soft);
  font-size: 28rpx;
  line-height: 1.8;
}

.participants-list {
  display: flex;
  flex-wrap: wrap;
}

.participant-item {
  display: flex;
  width: 120rpx;
  flex-direction: column;
  align-items: center;
  margin-right: 20rpx;
  margin-bottom: 16rpx;
}

.participant-avatar {
  width: 82rpx;
  height: 82rpx;
  margin-bottom: 8rpx;
  border-radius: 50%;
}

.participant-name {
  width: 100%;
  overflow: hidden;
  color: var(--tf-ink-soft);
  font-size: 22rpx;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.action-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  gap: 16rpx;
  padding: 20rpx 28rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -16rpx 40rpx oklch(28% 0.05 166 / 0.12);
}

.action-btn {
  display: flex;
  flex: 1;
  height: 88rpx;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  border: none;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 850;
  line-height: 1;
}

.action-btn::after {
  border: none;
}

.share-btn {
  color: var(--tf-ink-soft);
  background: oklch(95% 0.025 150);
}

.join-btn {
  color: oklch(100% 0 0);
  background: linear-gradient(135deg, var(--tf-primary), var(--tf-primary-deep));
}

.joined-btn {
  color: var(--tf-muted);
  background: oklch(90% 0.02 160);
}

.manage-btn {
  color: oklch(100% 0 0);
  background: linear-gradient(135deg, var(--tf-blue), oklch(44% 0.17 238));
}

.loading-container {
  display: flex;
  min-height: 400rpx;
  align-items: center;
  justify-content: center;
}

.loading-text {
  color: var(--tf-muted);
}
