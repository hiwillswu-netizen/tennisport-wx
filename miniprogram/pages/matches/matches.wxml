<!--pages/matches/matches.wxml-->
<view class="container">
  <!-- 顶部操作栏 -->
  <view class="top-bar">
    <view class="tabs-wrapper">
      <view 
        class="tab-item {{currentTab === 'all' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="all"
      >全部约球</view>
      <view 
        class="tab-item {{currentTab === 'mine' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="mine"
      >我发布的</view>
    </view>
    <view class="publish-btn" bindtap="goToPublish">
      <image class="publish-icon" src="/images/lucide/plus.svg" mode="aspectFit"/>
      <text class="publish-text">发布</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-wrapper">
    <view class="loading-spinner"></view>
    <text class="loading-text">正在加载约球信息...</text>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{matches.length === 0}}" class="empty-state">
    <image class="empty-icon-img" src="/images/lucide/users.svg" mode="aspectFit"/>
    <text class="empty-text">{{currentTab === 'mine' ? '您还没有发布过约球' : '暂无约球信息'}}</text>
    <view class="empty-action" bindtap="goToPublish">发布约球</view>
  </view>

  <!-- 约球列表 -->
  <scroll-view 
    wx:else 
    class="match-scroll" 
    scroll-y
    enhanced
    bindscrolltolower="loadMore"
    refresher-enabled
    bindrefresherrefresh="onRefresh"
    refresher-triggered="{{refreshing}}"
  >
    <view class="match-list">
      <view 
        class="match-card" 
        wx:for="{{matches}}" 
        wx:key="_id"
        bindtap="goToDetail"
        data-id="{{item._id}}"
        hover-class="match-card-hover"
      >
        <!-- 头部：用户信息和状态 -->
        <view class="match-header">
          <image class="match-avatar" src="{{item.userAvatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
          <view class="match-user-info">
            <text class="match-nickname">{{item.userNickname || '网球爱好者'}}</text>
            <text class="match-publish-time">{{item.createTimeStr}}</text>
          </view>
          <view class="match-status {{item.status === 'open' ? 'status-open' : 'status-closed'}}">
            {{item.status === 'open' ? '招募中' : '已满员'}}
          </view>
        </view>

        <!-- 内容区 -->
        <view class="match-body">
          <view class="match-info-row">
            <image class="info-icon icon-img" src="/images/lucide/calendar-days.svg" mode="aspectFit"/>
            <text class="info-text">{{item.matchDate}} {{item.matchTime}}</text>
          </view>
          <view class="match-info-row">
            <image class="info-icon icon-img" src="/images/lucide/map-pin.svg" mode="aspectFit"/>
            <text class="info-text">{{item.venueName || '待定'}}</text>
          </view>
          <view class="match-remark" wx:if="{{item.remark}}">
            <text class="remark-label">备注</text>
            <text class="remark-text">{{item.remark}}</text>
          </view>
        </view>

        <!-- 底部：人数和级别 -->
        <view class="match-footer">
          <view class="match-people">
            <text class="people-label">人数：</text>
            <text class="people-value">{{item.currentPeople || 1}}/{{item.needPeople || 4}}</text>
          </view>
          <view wx:if="{{item.level}}" class="level-tag">{{item.level}}</view>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view class="loadmore" wx:if="{{hasMore}}">
      <view class="loadmore-spinner"></view>
      <text class="loadmore-text">加载更多...</text>
    </view>
    <view class="loadmore-end" wx:if="{{!hasMore && matches.length > 0}}">
      <text class="loadmore-end-text">已经到底了</text>
    </view>
  </scroll-view>
</view>
