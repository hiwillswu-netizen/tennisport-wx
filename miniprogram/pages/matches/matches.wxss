/* pages/matches/matches.wxss */
.container {
  min-height: 100vh;
  background:
    linear-gradient(158deg, oklch(98% 0.035 110), oklch(95% 0.04 180) 54%, oklch(98% 0.03 80));
}

.top-bar {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 34rpx 24rpx 28rpx;
  background:
    linear-gradient(135deg, var(--tf-primary-deep), var(--tf-primary) 58%, var(--tf-accent));
  border-bottom-left-radius: 42rpx;
  box-shadow: 0 28rpx 60rpx oklch(27% 0.07 166 / 0.22);
}

.top-bar::after {
  content: '';
  position: absolute;
  width: 260rpx;
  height: 96rpx;
  right: -60rpx;
  bottom: 18rpx;
  transform: rotate(-16deg);
  border: 2rpx solid oklch(100% 0 0 / 0.22);
}

.tabs-wrapper {
  z-index: 1;
  display: flex;
  flex: 1;
  margin-right: 18rpx;
  padding: 8rpx;
  background: oklch(100% 0 0 / 0.14);
  border-radius: 999rpx;
}

.tab-item {
  flex: 1;
  padding: 18rpx 20rpx;
  color: oklch(96% 0.03 150 / 0.76);
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 800;
  text-align: center;
}

.tab-item.active {
  color: var(--tf-primary-deep);
  background: oklch(98% 0.045 118);
  box-shadow: 0 12rpx 28rpx oklch(20% 0.04 166 / 0.16);
}

.tab-item.active::after {
  display: none;
}

.publish-btn {
  z-index: 1;
  display: flex;
  align-items: center;
  padding: 18rpx 24rpx;
  background: #ffffff;
  border-radius: 999rpx;
  box-shadow: 0 14rpx 34rpx oklch(20% 0.06 166 / 0.2);
}

.publish-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
}

.publish-text {
  color: var(--tf-primary-deep);
  font-size: 26rpx;
  font-weight: 900;
}

.loading-wrapper,
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 40rpx;
}

.loading-spinner,
.loadmore-spinner {
  border: 4rpx solid oklch(89% 0.04 155);
  border-top-color: var(--tf-accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text,
.empty-text,
.loadmore-text,
.loadmore-end-text {
  color: var(--tf-muted);
  font-size: 26rpx;
}

.empty-action {
  margin-top: 34rpx;
  padding: 20rpx 58rpx;
  color: oklch(100% 0 0);
  background: linear-gradient(135deg, var(--tf-primary), var(--tf-primary-deep));
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.match-scroll {
  flex: 1;
  height: calc(100vh - 132rpx);
}

.match-list {
  padding: 22rpx 24rpx 40rpx;
}

.match-card {
  position: relative;
  overflow: hidden;
  margin-bottom: 26rpx;
  padding: 28rpx;
  background: #ffffff;
  border: 1rpx solid oklch(92% 0.04 150);
  border-radius: 30rpx;
  box-shadow: 0 24rpx 58rpx var(--tf-shadow);
}

.match-card:nth-child(2n) {
  margin-left: 0;
  border-top-right-radius: 30rpx;
}

.match-card:nth-child(3n) {
  margin-right: 0;
  border-bottom-left-radius: 30rpx;
}

.match-card::before {
  content: '';
  position: absolute;
  width: 170rpx;
  height: 170rpx;
  right: -62rpx;
  top: -60rpx;
  transform: rotate(22deg);
  background: oklch(92% 0.07 130);
  border-radius: 36rpx;
}

.match-card-hover {
  transform: scale(0.985);
}

.match-header,
.match-body,
.match-footer {
  position: relative;
  z-index: 1;
}

.match-header {
  display: flex;
  align-items: center;
  margin-bottom: 22rpx;
}

.match-avatar {
  width: 82rpx;
  height: 82rpx;
  margin-right: 18rpx;
  background: oklch(93% 0.04 150);
  border: 4rpx solid oklch(100% 0 0);
  border-radius: 50%;
  box-shadow: 0 10rpx 24rpx oklch(25% 0.05 166 / 0.12);
}

.match-user-info {
  display: flex;
  flex: 1;
  min-width: 0;
  flex-direction: column;
}

.match-nickname {
  margin-bottom: 4rpx;
  color: var(--tf-ink);
  font-size: 30rpx;
  font-weight: 850;
}

.match-publish-time {
  color: var(--tf-muted);
  font-size: 23rpx;
}

.match-status {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 900;
}

.status-open {
  color: var(--tf-primary-deep);
  background: var(--tf-primary-soft);
}

.status-closed {
  color: var(--tf-muted);
  background: oklch(93% 0.02 160);
}

.match-body {
  padding: 20rpx 0;
  border-top: 1rpx solid oklch(92% 0.03 150);
  border-bottom: 1rpx solid oklch(92% 0.03 150);
}

.match-info-row {
  display: flex;
  align-items: center;
  margin-bottom: 14rpx;
}

.match-info-row:last-child {
  margin-bottom: 0;
}

.info-icon {
  margin-right: 12rpx;
}

.info-text {
  color: var(--tf-ink);
  font-size: 28rpx;
  font-weight: 650;
}

.match-remark {
  display: flex;
  align-items: baseline;
  margin-top: 16rpx;
  padding: 12rpx 0 0;
  border-top: 1rpx dashed #d7e5dd;
}

.remark-label {
  flex-shrink: 0;
  width: 58rpx;
  margin-right: 12rpx;
  padding: 0;
  color: #0f7a58;
  background: transparent;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 36rpx;
}

.remark-text {
  flex: 1;
  color: #5f716b;
  font-size: 26rpx;
  line-height: 36rpx;
}

.match-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
}

.match-people {
  font-size: 26rpx;
}

.people-label {
  color: var(--tf-muted);
}

.people-value {
  color: var(--tf-primary-deep);
  font-weight: 900;
}

.level-tag {
  display: inline-block;
  padding: 9rpx 16rpx;
  color: var(--tf-accent-deep);
  background: oklch(94% 0.08 70);
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 850;
}

.loadmore {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
}

.loadmore-spinner {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.loadmore-end {
  display: flex;
  justify-content: center;
  padding: 32rpx 0 52rpx;
}
