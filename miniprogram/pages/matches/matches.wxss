/* pages/matches/matches.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #fff;
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.tabs-wrapper {
  display: flex;
  flex: 1;
  margin-right: 20rpx;
}

.tab-item {
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #16a34a;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #16a34a;
  border-radius: 2rpx;
}

.publish-btn {
  display: flex;
  align-items: center;
  background-color: #16a34a;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
}

.publish-icon {
  font-size: 28rpx;
  color: #fff;
  margin-right: 6rpx;
}

.publish-text {
  font-size: 26rpx;
  color: #fff;
}

.loading-wrapper {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 120rpx 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e5e5e5;
  border-top-color: #16a34a;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
  margin-bottom: 40rpx;
}

.empty-action {
  padding: 20rpx 60rpx;
  background-color: #16a34a;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.match-scroll {
  flex: 1;
  height: calc(100vh - 120rpx);
}

.match-list {
  padding: 10rpx 0;
}

.match-card {
  background-color: #fff;
  margin: 20rpx 24rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.match-card-hover {
  background-color: #f9fafb;
}

.match-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.match-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background-color: #f0f0f0;
}

.match-user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.match-nickname {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 6rpx;
}

.match-publish-time {
  font-size: 24rpx;
  color: #999;
}

.match-status {
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-open {
  background-color: #dcfce7;
  color: #16a34a;
}

.status-closed {
  background-color: #f3f4f6;
  color: #6b7280;
}

.match-body {
  padding: 20rpx 0;
  border-top: 1rpx solid #f5f5f5;
  border-bottom: 1rpx solid #f5f5f5;
}

.match-info-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.match-info-row:last-child {
  margin-bottom: 0;
}

.info-icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.info-text {
  font-size: 28rpx;
  color: #333;
}

.match-remark {
  margin-top: 16rpx;
  padding: 16rpx;
  background-color: #f9fafb;
  border-radius: 8rpx;
}

.remark-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.match-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}

.match-people {
  font-size: 26rpx;
}

.people-label {
  color: #999;
}

.people-value {
  color: #16a34a;
  font-weight: 600;
}

.level-tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  background-color: #fef3c7;
  color: #d97706;
  border-radius: 6rpx;
  font-size: 24rpx;
}

/* 加载更多 */
.loadmore {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
}

.loadmore-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #e5e5e5;
  border-top-color: #16a34a;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-right: 12rpx;
}

.loadmore-text {
  color: #999;
  font-size: 24rpx;
}

.loadmore-end {
  display: flex;
  justify-content: center;
  padding: 32rpx 0;
}

.loadmore-end-text {
  color: #ccc;
  font-size: 24rpx;
}
