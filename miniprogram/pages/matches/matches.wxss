/* pages/matches/matches.wxss */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #fff;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab-bar {
  display: flex;
}

.tab-item {
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  color: #666;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.tab-item.active {
  background-color: #dcfce7;
  color: #16a34a;
  font-weight: 500;
}

.publish-btn {
  background-color: #16a34a;
  color: #fff;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.match-scroll {
  flex: 1;
  height: calc(100vh - 140rpx);
}

.match-card {
  background-color: #fff;
  margin: 20rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.match-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.match-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.match-user-info {
  flex: 1;
}

.match-nickname {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 4rpx;
}

.match-publish-time {
  font-size: 24rpx;
  color: #999;
}

.match-status {
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-open {
  background-color: #dcfce7;
  color: #16a34a;
}

.status-closed {
  background-color: #f3f4f6;
  color: #6b7280;
}

.match-body {
  padding: 16rpx 0;
  border-top: 1rpx solid #f5f5f5;
  border-bottom: 1rpx solid #f5f5f5;
}

.match-datetime,
.match-venue {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.datetime-icon,
.venue-icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.datetime-text,
.venue-text {
  font-size: 28rpx;
  color: #333;
}

.match-remark {
  margin-top: 16rpx;
  padding: 16rpx;
  background-color: #f9fafb;
  border-radius: 8rpx;
}

.remark-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.match-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}

.match-people {
  font-size: 26rpx;
}

.people-label {
  color: #999;
}

.people-value {
  color: #16a34a;
  font-weight: 600;
}

.level-tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  background-color: #fef3c7;
  color: #d97706;
  border-radius: 6rpx;
  font-size: 24rpx;
}

.publish-btn-empty {
  margin-top: 32rpx;
  width: 240rpx !important;
}

.load-more, .no-more {
  padding: 32rpx;
  text-align: center;
}

.no-more text {
  color: #ccc;
  font-size: 24rpx;
}
