/* pages/publish-match/publish-match.wxss */
.container {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 210rpx;
  background:
    linear-gradient(158deg, oklch(98% 0.035 110), oklch(95% 0.04 180) 54%, oklch(98% 0.03 78));
}

.form-card {
  overflow: hidden;
  padding: 12rpx 30rpx;
  background: #ffffff;
  border: 1rpx solid oklch(92% 0.04 150);
  border-radius: 30rpx 30rpx 8rpx 30rpx;
  box-shadow: 0 24rpx 58rpx var(--tf-shadow);
}

.form-item {
  padding: 26rpx 0;
  border-bottom: 1rpx solid oklch(92% 0.03 150);
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  margin-bottom: 16rpx;
  color: var(--tf-ink);
  font-size: 28rpx;
  font-weight: 850;
}

.form-label.required::before {
  content: '*';
  margin-right: 6rpx;
  color: var(--tf-danger);
}

.form-input {
  color: var(--tf-ink);
  font-size: 28rpx;
  font-weight: 650;
  padding: 16rpx 0;
}

.form-input.picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.placeholder,
.form-input .placeholder,
.time-picker .placeholder {
  color: var(--tf-muted);
  font-weight: 500;
}

.arrow {
  color: var(--tf-primary-deep);
  font-size: 24rpx;
  font-weight: 900;
}

.form-textarea {
  box-sizing: border-box;
  width: 100%;
  height: 170rpx;
  padding: 18rpx;
  color: var(--tf-ink);
  background: #f8fbf8;
  border-radius: 20rpx;
  font-size: 28rpx;
}

.char-count {
  display: block;
  margin-top: 8rpx;
  color: var(--tf-muted);
  font-size: 22rpx;
  text-align: right;
}

.submit-section {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -16rpx 40rpx oklch(28% 0.05 166 / 0.12);
}

.submit-btn {
  display: flex;
  width: 100%;
  height: 96rpx;
  align-items: center;
  justify-content: center;
  color: oklch(100% 0 0);
  background: linear-gradient(135deg, var(--tf-primary), var(--tf-primary-deep));
  border: none;
  border-radius: 999rpx;
  font-size: 32rpx;
  font-weight: 900;
}

.submit-btn::after {
  border: none;
}

.submit-btn[loading] {
  background: oklch(74% 0.12 154);
}

.submit-tip {
  display: block;
  margin-top: 16rpx;
  color: var(--tf-muted);
  font-size: 24rpx;
  text-align: center;
}

.time-range {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.time-picker {
  flex: 1;
  padding: 21rpx 24rpx;
  color: var(--tf-ink);
  background: #f8fbf8;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
}

.time-separator {
  padding: 0 20rpx;
  color: var(--tf-ink-soft);
  font-size: 28rpx;
}
