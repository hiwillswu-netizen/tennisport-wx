<!--pages/venue-detail/venue-detail.wxml-->
<view class="container" wx:if="{{venue}}">
  <!-- 场馆基本信息 -->
  <view class="venue-header">
    <view class="venue-name">{{venue.name}}</view>
    <view class="venue-tags">
      <text class="tag {{venue.type === '室内' ? 'tag-indoor' : 'tag-outdoor'}}">{{venue.type}}</text>
      <text class="tag tag-default">{{venue.courtType}}</text>
      <text class="tag tag-default">{{venue.district}}</text>
    </view>
  </view>

  <!-- 详细信息卡片 -->
  <view class="info-card">
    <view class="info-section">
      <view class="info-title">场地信息</view>
      <view class="info-row">
        <text class="info-label">场地数量</text>
        <text class="info-value">{{venue.courtsCount || '-'}} 片</text>
      </view>
      <view class="info-row">
        <text class="info-label">场地类型</text>
        <text class="info-value">{{venue.courtType}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">室内/室外</text>
        <text class="info-value">{{venue.type}}</text>
      </view>
    </view>

    <view class="info-section">
      <view class="info-title">价格信息</view>
      <view class="info-row" wx:if="{{venue.priceWeekday}}">
        <text class="info-label">工作日</text>
        <text class="info-value price">{{venue.priceWeekday}}</text>
      </view>
      <view class="info-row" wx:if="{{venue.priceWeekend}}">
        <text class="info-label">周末</text>
        <text class="info-value price">{{venue.priceWeekend}}</text>
      </view>
      <view class="info-row" wx:if="{{venue.priceEvening}}">
        <text class="info-label">晚间</text>
        <text class="info-value price">{{venue.priceEvening}}</text>
      </view>
    </view>

    <view class="info-section">
      <view class="info-title">营业时间</view>
      <view class="info-row">
        <text class="info-value">{{venue.hours || '请致电咨询'}}</text>
      </view>
    </view>

    <view class="info-section">
      <view class="info-title">联系方式</view>
      <view class="info-row clickable" bindtap="makePhoneCall" wx:if="{{venue.phone}}">
        <text class="info-label">电话</text>
        <text class="info-value link">{{venue.phone}} ></text>
      </view>
      <view class="info-row" wx:else>
        <text class="info-value">暂无联系电话</text>
      </view>
    </view>

    <view class="info-section">
      <view class="info-title">地址</view>
      <view class="info-row clickable" bindtap="openLocation">
        <text class="info-value link">{{venue.address}} 📍</text>
      </view>
    </view>
  </view>

  <!-- 标签 -->
  <view class="tags-card" wx:if="{{tagsArray.length > 0}}">
    <view class="card-title">特色标签</view>
    <view class="tags-list">
      <text class="feature-tag" wx:for="{{tagsArray}}" wx:key="*this">{{item}}</text>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="action-bar">
    <button class="action-btn secondary" bindtap="shareVenue" open-type="share">
      <text>分享</text>
    </button>
    <button class="action-btn primary" bindtap="publishMatch">
      <text>在此约球</text>
    </button>
  </view>
</view>

<!-- 加载状态 -->
<view class="loading-container" wx:if="{{loading}}">
  <text class="loading-text">加载中...</text>
</view>

<!-- 错误状态 -->
<view class="error-container" wx:if="{{error}}">
  <text class="error-text">{{error}}</text>
  <button class="btn-primary" bindtap="loadVenue">重试</button>
</view>
