<!--pages/venue-detail/venue-detail.wxml-->
<view class="container" wx:if="{{venue}}">
  <!-- 顶部banner区 -->
  <view class="header-banner">
    <view class="banner-pattern"></view>
    <view class="banner-content">
      <view class="banner-tags">
        <view class="type-tag {{venue.type === '室内' ? 'indoor' : 'outdoor'}}">{{venue.type}}</view>
        <view class="court-tag">{{venue.courtType || '硬地'}}</view>
      </view>
    </view>
  </view>

  <!-- 主要内容区 -->
  <view class="main-content">
    <!-- 场馆名称和基本信息 -->
    <view class="venue-info-card">
      <view class="venue-name">{{venue.name}}</view>
      
      <!-- 地址 -->
      <view class="info-row" bindtap="openLocation">
        <image class="row-icon" src="/images/lucide/map-pin.svg" mode="aspectFit"/>
        <text class="row-text">{{venue.address}}</text>
        <view class="row-action nav-action">
          <image class="action-icon" src="/images/lucide/navigation.svg" mode="aspectFit"/>
          <text class="action-text">导航</text>
        </view>
      </view>
      
      <!-- 电话 -->
      <view class="info-row" wx:if="{{venue.phone}}" bindtap="makePhoneCall">
        <image class="row-icon" src="/images/lucide/phone.svg" mode="aspectFit"/>
        <text class="row-text">{{venue.phone}}</text>
        <view class="row-action call-action">
          <image class="action-icon" src="/images/lucide/smartphone.svg" mode="aspectFit"/>
          <text class="action-text">拨打</text>
        </view>
      </view>
      
      <!-- 营业时间 -->
      <view class="info-row">
        <image class="row-icon" src="/images/lucide/clock.svg" mode="aspectFit"/>
        <text class="row-text">{{venue.hours || '06:00-22:00'}}</text>
      </view>
    </view>

    <!-- 收费标准 -->
    <view class="section-card" wx:if="{{venue.priceWeekday || venue.priceWeekend || venue.priceEvening}}">
      <view class="section-header">
        <image class="section-icon" src="/images/lucide/dollar-sign.svg" mode="aspectFit"/>
        <text class="section-title">收费标准</text>
      </view>
      <view class="price-list">
        <view class="price-row" wx:if="{{venue.priceWeekday}}">
          <text class="price-label">工作日</text>
          <text class="price-value">{{venue.priceWeekday}}</text>
        </view>
        <view class="price-row" wx:if="{{venue.priceWeekend}}">
          <text class="price-label">周末</text>
          <text class="price-value">{{venue.priceWeekend}}</text>
        </view>
        <view class="price-row highlight" wx:if="{{venue.priceEvening}}">
          <text class="price-label">晚间</text>
          <text class="price-value evening">{{venue.priceEvening}}</text>
        </view>
      </view>
    </view>

    <!-- 场地信息 -->
    <view class="section-card">
      <view class="section-header">
        <image class="section-icon" src="/images/lucide/circle-dot.svg" mode="aspectFit"/>
        <text class="section-title">场地信息</text>
      </view>
      <view class="info-grid">
        <view class="info-block">
          <text class="block-label">场地数量</text>
          <text class="block-value">{{venue.courtsCount || '-'}} <text class="block-unit">片</text></text>
        </view>
        <view class="info-block">
          <text class="block-label">场地类型</text>
          <text class="block-value">{{venue.courtType || '硬地'}}</text>
        </view>
      </view>
    </view>

    <!-- 场馆特色 -->
    <view class="section-card" wx:if="{{tagsArray.length > 0}}">
      <view class="section-header">
        <image class="section-icon" src="/images/lucide/tag.svg" mode="aspectFit"/>
        <text class="section-title">场馆特色</text>
      </view>
      <view class="tags-wrap">
        <view class="feature-tag" wx:for="{{tagsArray}}" wx:key="*this">{{item}}</view>
      </view>
    </view>

    <!-- 操作区块 -->
    <view class="action-section">
      <button class="inline-action-btn secondary {{isFavorited ? 'favorited' : ''}}" bindtap="toggleFavorite">
        <image class="btn-icon" src="/images/lucide/heart.svg" mode="aspectFit"/>
        <text class="btn-text">{{isFavorited ? '已收藏' : '收藏'}}</text>
      </button>
      <button class="inline-action-btn primary" bindtap="publishMatch">
        <image class="btn-icon" src="/images/lucide/circle-dot-white.svg" mode="aspectFit"/>
        <text class="btn-text">在此约球</text>
      </button>
    </view>

    <!-- 底部安全距离 -->
    <view class="bottom-safe-area"></view>
  </view>

  <!-- 底部吸底预定按钮 -->
  <view class="booking-bar-wrapper" wx:if="{{venue.bookingAppId || venue.bookingMiniProgram}}">
    <view class="booking-bar" bindtap="navigateToBooking">
      <text class="booking-text">立即预定</text>
      <text class="booking-arrow">›</text>
    </view>
  </view>
</view>

<!-- 加载状态 -->
<view class="loading-container" wx:if="{{loading}}">
  <view class="loading-spinner"></view>
  <text class="loading-text">加载中...</text>
</view>

<!-- 错误状态 -->
<view class="error-container" wx:if="{{error}}">
  <image class="error-icon" src="/images/lucide/circle-alert.svg" mode="aspectFit"/>
  <text class="error-text">{{error}}</text>
  <view class="retry-btn" bindtap="loadVenue">重试</view>
</view>
