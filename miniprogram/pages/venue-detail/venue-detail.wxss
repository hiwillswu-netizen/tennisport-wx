/* pages/venue-detail/venue-detail.wxss */
.container {
  padding-bottom: 140rpx;
}

.venue-header {
  background-color: #16a34a;
  padding: 40rpx 30rpx;
  color: #fff;
}

.venue-name {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.venue-tags .tag {
  background-color: rgba(255, 255, 255, 0.2);
  color: #fff;
}

.info-card {
  background-color: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.info-section {
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-section:last-child {
  border-bottom: none;
}

.info-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.info-row.clickable {
  padding: 16rpx 0;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
}

.info-value.price {
  color: #ea580c;
  font-weight: 500;
}

.info-value.link {
  color: #16a34a;
}

.tags-card {
  background-color: #fff;
  margin: 20rpx;
  padding: 24rpx 30rpx;
  border-radius: 16rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.tags-list {
  display: flex;
  flex-wrap: wrap;
}

.feature-tag {
  display: inline-block;
  padding: 10rpx 20rpx;
  margin: 8rpx 12rpx 8rpx 0;
  background-color: #f0fdf4;
  color: #16a34a;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  margin: 0 10rpx;
}

.action-btn.primary {
  background-color: #16a34a;
  color: #fff;
}

.action-btn.secondary {
  background-color: #fff;
  color: #16a34a;
  border: 2rpx solid #16a34a;
}

.loading-container,
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 400rpx;
  padding: 40rpx;
}

.error-text {
  color: #ef4444;
  margin-bottom: 24rpx;
}
