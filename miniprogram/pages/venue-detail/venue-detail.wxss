/* pages/venue-detail/venue-detail.wxss */
page {
  background-color: #f5f5f5;
}

.container {
  padding-bottom: calc(env(safe-area-inset-bottom) + 80rpx);
}

/* 顶部banner */
.header-banner {
  position: relative;
  height: 200rpx;
  background: linear-gradient(135deg, #16a34a, #22c55e);
  overflow: hidden;
}

.banner-pattern {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  opacity: 0.15;
  background-image: 
    radial-gradient(circle at 20% 30%, rgba(255,255,255,0.3) 2rpx, transparent 2rpx),
    radial-gradient(circle at 70% 60%, rgba(255,255,255,0.3) 2rpx, transparent 2rpx),
    radial-gradient(circle at 40% 80%, rgba(255,255,255,0.3) 2rpx, transparent 2rpx);
  background-size: 80rpx 80rpx;
}

.banner-content {
  position: absolute;
  bottom: 24rpx;
  left: 32rpx;
}

.banner-tags {
  display: flex;
  gap: 16rpx;
}

.type-tag {
  padding: 10rpx 24rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.type-tag.indoor {
  background-color: rgba(59, 130, 246, 0.9);
  color: #fff;
}

.type-tag.outdoor {
  background-color: rgba(34, 197, 94, 0.9);
  color: #fff;
}

.court-tag {
  padding: 10rpx 24rpx;
  background-color: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(8rpx);
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #fff;
}

/* 主内容区 */
.main-content {
  margin-top: -20rpx;
  position: relative;
}

/* 场馆信息卡片 */
.venue-info-card {
  background-color: #fff;
  margin: 0 24rpx 20rpx;
  padding: 32rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.venue-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 24rpx;
  line-height: 1.3;
}

.info-row {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.row-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.row-text {
  flex: 1;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.row-action {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  border-radius: 32rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.nav-action {
  background-color: #dcfce7;
}

.nav-action .action-text {
  color: #16a34a;
}

.call-action {
  background-color: #dbeafe;
}

.call-action .action-text {
  color: #2563eb;
}

.action-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.action-text {
  font-size: 24rpx;
  font-weight: 500;
}

/* 信息区块 */
.section-card {
  background-color: #fff;
  margin: 0 24rpx 20rpx;
  padding: 28rpx 32rpx;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

/* 价格列表 */
.price-list {
  background-color: #f9fafb;
  border-radius: 16rpx;
  overflow: hidden;
}

.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.price-row:last-child {
  border-bottom: none;
}

.price-label {
  font-size: 28rpx;
  color: #666;
}

.price-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.price-value.evening {
  color: #f97316;
}

/* 信息网格 */
.info-grid {
  display: flex;
  gap: 20rpx;
}

.info-block {
  flex: 1;
  background-color: #f9fafb;
  border-radius: 16rpx;
  padding: 24rpx;
}

.block-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.block-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.block-unit {
  font-size: 24rpx;
  font-weight: 400;
  color: #666;
}

/* 标签 */
.tags-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.feature-tag {
  padding: 12rpx 24rpx;
  background-color: #dcfce7;
  color: #16a34a;
  font-size: 26rpx;
  border-radius: 32rpx;
}

/* 预订信息 */
.booking-info {
  background-color: #f9fafb;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.booking-row {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
}

.booking-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.booking-dot.green {
  background-color: #16a34a;
}

.booking-dot.blue {
  background-color: #3b82f6;
}

.booking-text {
  font-size: 26rpx;
  color: #666;
}

/* 底部安全距离 */
.bottom-safe-area {
  height: calc(env(safe-area-inset-bottom) + 40rpx);
}

/* 操作区块 */
.action-section {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin: 20rpx 24rpx 0;
  padding: 24rpx;
  background-color: #fff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.inline-action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  border-radius: 48rpx;
  font-size: 28rpx;
  padding: 0;
  margin: 0;
  line-height: 1;
  background-color: transparent;
}

.inline-action-btn::after {
  border: none;
}

.inline-action-btn.primary {
  flex: 1;
  padding: 18rpx 32rpx;
  background-color: #16a34a;
  color: #fff;
}

.inline-action-btn.secondary {
  flex: 1;
  padding: 18rpx 28rpx;
  background-color: #f5f5f5;
}

.inline-action-btn.secondary.favorited {
  background-color: #fef2f2;
}

.inline-action-btn.secondary.favorited .btn-text {
  color: #ef4444;
}

.inline-action-btn .btn-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.inline-action-btn .btn-text {
  font-size: 28rpx;
  font-weight: 500;
}

.inline-action-btn.secondary .btn-text {
  color: #666;
}

.inline-action-btn.primary .btn-text {
  color: #fff;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e5e5e5;
  border-top-color: #16a34a;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 错误状态 */
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.error-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 32rpx;
}

.retry-btn {
  padding: 20rpx 60rpx;
  background-color: #16a34a;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

/* 底部吸底预定按钮 */
.booking-bar-wrapper {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  z-index: 100;
}

.booking-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 24rpx 40rpx;
  background: linear-gradient(135deg, #2563eb, #3b82f6);
  border-radius: 48rpx;
  box-shadow: 0 4rpx 16rpx rgba(37, 99, 235, 0.3);
}

.booking-bar:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(37, 99, 235, 0.3);
}

.booking-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.booking-arrow {
  font-size: 36rpx;
  font-weight: 300;
  color: #fff;
  margin-left: 8rpx;
}
