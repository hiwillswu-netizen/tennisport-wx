/* pages/venue-detail/venue-detail.wxss */
page {
  background: var(--tf-primary-deep);
}

.container {
  min-height: 100vh;
  padding-bottom: calc(env(safe-area-inset-bottom) + 96rpx);
  background:
    linear-gradient(158deg, oklch(98% 0.035 110), oklch(95% 0.04 180) 54%, oklch(98% 0.03 78));
}

.header-banner {
  position: relative;
  height: 246rpx;
  overflow: hidden;
  background:
    linear-gradient(135deg, var(--tf-primary-deep), var(--tf-primary) 58%, var(--tf-accent));
  border-bottom-left-radius: 48rpx;
}

.banner-pattern {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  opacity: 0.32;
  background:
    repeating-linear-gradient(90deg, oklch(100% 0 0 / 0.28) 0 2rpx, transparent 2rpx 30rpx),
    repeating-linear-gradient(0deg, oklch(100% 0 0 / 0.18) 0 2rpx, transparent 2rpx 30rpx);
  transform: rotate(-8deg) scale(1.2);
}

.header-banner::after {
  content: '';
  position: absolute;
  width: 170rpx;
  height: 170rpx;
  right: 42rpx;
  top: 36rpx;
  border: 5rpx solid oklch(91% 0.17 118 / 0.42);
  border-radius: 50%;
}

.banner-content {
  position: absolute;
  left: 30rpx;
  bottom: 34rpx;
}

.banner-tags {
  display: flex;
  gap: 14rpx;
}

.type-tag,
.court-tag {
  padding: 11rpx 22rpx;
  border-radius: 999rpx;
  font-size: 25rpx;
  font-weight: 850;
}

.type-tag.indoor {
  color: oklch(96% 0.02 235);
  background: oklch(48% 0.16 235 / 0.88);
}

.type-tag.outdoor {
  color: var(--tf-primary-deep);
  background: oklch(96% 0.08 130);
}

.court-tag {
  color: oklch(100% 0 0);
  background: oklch(100% 0 0 / 0.18);
  border: 1rpx solid oklch(100% 0 0 / 0.22);
}

.main-content {
  position: relative;
  margin-top: -34rpx;
}

.venue-info-card,
.section-card,
.action-section {
  margin: 0 24rpx 22rpx;
  background: #ffffff;
  border: 1rpx solid oklch(92% 0.04 150);
  border-radius: 30rpx;
  box-shadow: 0 22rpx 56rpx var(--tf-shadow);
}

.venue-info-card {
  padding: 34rpx;
  border-top-left-radius: 10rpx;
}

.venue-name {
  margin-bottom: 24rpx;
  color: var(--tf-ink);
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.28;
}

.info-row {
  display: flex;
  align-items: flex-start;
  padding: 18rpx 0;
  border-bottom: 1rpx solid oklch(92% 0.03 150);
}

.info-row:last-child {
  border-bottom: none;
}

.row-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  margin-top: 6rpx;
}

.row-text {
  flex: 1;
  color: var(--tf-ink-soft);
  font-size: 28rpx;
  line-height: 1.6;
}

.row-action {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  margin-left: 16rpx;
  padding: 11rpx 18rpx;
  border-radius: 999rpx;
}

.nav-action {
  background: var(--tf-primary-soft);
}

.call-action {
  background: oklch(93% 0.06 235);
}

.action-icon {
  width: 25rpx;
  height: 25rpx;
  margin-right: 6rpx;
}

.action-text {
  color: var(--tf-primary-deep);
  font-size: 24rpx;
  font-weight: 850;
}

.section-card {
  padding: 30rpx 32rpx;
}

.section-card:nth-of-type(2n) {
  margin-left: 24rpx;
  border-top-left-radius: 30rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-icon {
  width: 34rpx;
  height: 34rpx;
  margin-right: 12rpx;
}

.section-title {
  color: var(--tf-ink);
  font-size: 32rpx;
  font-weight: 900;
}

.price-list {
  overflow: hidden;
  background: oklch(96% 0.035 118);
  border-radius: 22rpx;
}

.price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 24rpx;
  border-bottom: 1rpx solid oklch(90% 0.035 150);
}

.price-row:last-child {
  border-bottom: none;
}

.price-row.highlight {
  background: transparent;
}

.price-label {
  color: var(--tf-ink-soft);
  font-size: 28rpx;
}

.price-value {
  color: var(--tf-ink);
  font-size: 28rpx;
  font-weight: 900;
}

.price-value.evening {
  color: var(--tf-ink);
}

.info-grid {
  display: flex;
  gap: 18rpx;
}

.info-block {
  flex: 1;
  padding: 26rpx;
  background: oklch(96% 0.035 118);
  border-radius: 24rpx 24rpx 8rpx 24rpx;
}

.block-label {
  display: block;
  margin-bottom: 8rpx;
  color: var(--tf-muted);
  font-size: 24rpx;
}

.block-value {
  color: var(--tf-primary-deep);
  font-family: var(--tf-display);
  font-size: 38rpx;
  font-weight: 850;
}

.block-unit {
  color: var(--tf-ink-soft);
  font-family: var(--tf-body);
  font-size: 24rpx;
  font-weight: 500;
}

.tags-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.feature-tag {
  padding: 13rpx 23rpx;
  color: var(--tf-primary-deep);
  background: var(--tf-primary-soft);
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.bottom-safe-area {
  height: calc(env(safe-area-inset-bottom) + 42rpx);
}

.action-section {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  padding: 22rpx;
}

.inline-action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  border: none;
  border-radius: 999rpx;
  background: transparent;
  font-size: 28rpx;
  line-height: 1;
}

.inline-action-btn::after {
  border: none;
}

.inline-action-btn.primary,
.inline-action-btn.secondary {
  flex: 1;
  padding: 22rpx 28rpx;
}

.inline-action-btn.primary {
  color: oklch(100% 0 0);
  background: linear-gradient(135deg, var(--tf-primary), var(--tf-primary-deep));
  box-shadow: 0 12rpx 28rpx rgba(15, 122, 88, 0.24);
}

.inline-action-btn.secondary {
  background: oklch(95% 0.025 150);
}

.inline-action-btn.secondary.favorited {
  background: oklch(94% 0.06 27);
}

.btn-icon {
  width: 30rpx;
  height: 30rpx;
  margin-right: 8rpx;
}

.btn-text {
  font-size: 28rpx;
  font-weight: 850;
}

.inline-action-btn.secondary .btn-text {
  color: var(--tf-ink-soft);
}

.inline-action-btn.secondary.favorited .btn-text {
  color: var(--tf-danger);
}

.inline-action-btn.primary .btn-text {
  color: #fffffb;
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.2);
}

.loading-container,
.error-container {
  display: flex;
  min-height: 100vh;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: var(--tf-surface);
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  margin-bottom: 20rpx;
  border: 4rpx solid oklch(89% 0.04 155);
  border-top-color: var(--tf-accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text,
.error-text {
  color: var(--tf-muted);
  font-size: 28rpx;
}

.error-icon {
  width: 82rpx;
  height: 82rpx;
  margin-bottom: 24rpx;
}

.retry-btn {
  margin-top: 32rpx;
  padding: 20rpx 60rpx;
  color: oklch(100% 0 0);
  background: linear-gradient(135deg, var(--tf-primary), var(--tf-primary-deep));
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.booking-bar-wrapper {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -16rpx 40rpx oklch(28% 0.05 166 / 0.12);
}

.booking-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 40rpx;
  background: linear-gradient(135deg, var(--tf-accent), var(--tf-accent-deep));
  border-radius: 999rpx;
  box-shadow: 0 14rpx 34rpx oklch(54% 0.19 36 / 0.28);
}

.booking-bar:active {
  transform: scale(0.985);
}

.booking-text,
.booking-arrow {
  color: #fffffb;
  font-size: 32rpx;
  font-weight: 900;
  text-shadow: 0 2rpx 6rpx rgba(112, 49, 8, 0.28);
}

.booking-arrow {
  margin-left: 8rpx;
}
