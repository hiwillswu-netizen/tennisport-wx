<!--pages/favorites/favorites.wxml-->
<view class="container">
  <!-- 加载中 -->
  <view class="loading-wrapper" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:elif="{{!loading && venues.length === 0}}">
    <image class="empty-icon-img" src="/images/lucide/heart.svg" mode="aspectFit"/>
    <text class="empty-text">暂无收藏场馆</text>
    <view class="empty-action" bindtap="goToVenues">去逛逛</view>
  </view>

  <!-- 收藏列表 -->
  <view class="venue-list" wx:else>
    <view class="venue-card" 
          wx:for="{{venues}}" 
          wx:key="_id"
          bindtap="goToDetail"
          data-id="{{item._id}}"
          hover-class="venue-card-hover">
      <view class="venue-header">
        <text class="venue-name">{{item.name}}</text>
        <view class="venue-type {{item.type === '室内' ? 'type-indoor' : 'type-outdoor'}}">{{item.type}}</view>
      </view>
      <view class="venue-address">
        <image class="icon icon-img" src="/images/lucide/map-pin.svg" mode="aspectFit"/>
        <text class="address-text">{{item.address}}</text>
      </view>
      <view class="venue-info-row">
        <view class="info-item" wx:if="{{item.hours}}">
          <image class="icon icon-img" src="/images/lucide/clock.svg" mode="aspectFit"/>
          <text class="info-text">{{item.hours}}</text>
        </view>
        <view class="info-item" wx:if="{{item.phone}}">
          <image class="icon icon-img" src="/images/lucide/phone.svg" mode="aspectFit"/>
          <text class="info-text">{{item.phone}}</text>
        </view>
      </view>
      <view class="venue-footer">
        <view class="venue-tags">
          <view class="tag" wx:for="{{item.tagsArray}}" wx:for-item="tag" wx:key="*this">{{tag}}</view>
        </view>
        <view class="remove-btn" catchtap="removeFavorite" data-id="{{item._id}}">
          <image class="remove-icon" src="/images/lucide/trash-2.svg" mode="aspectFit"/>
        </view>
      </view>
    </view>
  </view>
</view>
