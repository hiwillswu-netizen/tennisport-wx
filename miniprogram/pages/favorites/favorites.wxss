/* pages/favorites/favorites.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 加载状态 */
.loading-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e5e5e5;
  border-top-color: #16a34a;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.empty-action {
  padding: 20rpx 60rpx;
  background-color: #16a34a;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

/* 场馆列表 */
.venue-list {
  padding: 20rpx 24rpx;
}

/* 场馆卡片 */
.venue-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #f0f0f0;
  transition: all 0.15s;
}

.venue-card-hover {
  transform: scale(0.98);
  background-color: #fafafa;
}

.venue-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.venue-name {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.4;
  margin-right: 16rpx;
}

.venue-type {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.type-indoor {
  background-color: #dbeafe;
  color: #2563eb;
}

.type-outdoor {
  background-color: #dcfce7;
  color: #16a34a;
}

.venue-address {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.venue-address .icon {
  font-size: 24rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.address-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.venue-info-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.info-item {
  display: flex;
  align-items: center;
}

.info-item .icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.info-text {
  font-size: 24rpx;
  color: #999;
}

.venue-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.venue-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  flex: 1;
}

.tag {
  padding: 6rpx 14rpx;
  background-color: #f5f5f5;
  color: #666;
  font-size: 22rpx;
  border-radius: 6rpx;
}

.remove-btn {
  padding: 16rpx;
  margin: -16rpx;
  margin-left: 16rpx;
}

.remove-icon {
  font-size: 32rpx;
}
