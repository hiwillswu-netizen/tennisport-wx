/* pages/favorites/favorites.wxss */
.container {
  min-height: 100vh;
  background:
    linear-gradient(158deg, oklch(98% 0.035 110), oklch(95% 0.04 180) 54%, oklch(98% 0.03 78));
}

.loading-wrapper,
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 180rpx 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  margin-bottom: 20rpx;
  border: 4rpx solid oklch(89% 0.04 155);
  border-top-color: var(--tf-accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text,
.empty-text {
  color: var(--tf-muted);
  font-size: 28rpx;
}

.empty-action {
  margin-top: 32rpx;
  padding: 20rpx 58rpx;
  color: oklch(100% 0 0);
  background: linear-gradient(135deg, var(--tf-primary), var(--tf-primary-deep));
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 850;
}

.venue-list {
  padding: 24rpx;
}

.venue-card {
  position: relative;
  overflow: hidden;
  margin-bottom: 24rpx;
  padding: 28rpx;
  background: #ffffff;
  border: 1rpx solid oklch(92% 0.04 150);
  border-radius: 30rpx;
  box-shadow: 0 22rpx 54rpx var(--tf-shadow);
}

.venue-card:nth-child(2n) {
  margin-left: 34rpx;
  border-top-left-radius: 8rpx;
}

.venue-card-hover {
  transform: scale(0.985);
}

.venue-header,
.venue-address,
.venue-info-row,
.venue-footer {
  position: relative;
  z-index: 1;
}

.venue-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.venue-name {
  flex: 1;
  margin-right: 16rpx;
  color: var(--tf-ink);
  font-size: 32rpx;
  font-weight: 850;
  line-height: 1.4;
}

.venue-type {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 850;
}

.type-indoor {
  color: oklch(42% 0.15 235);
  background: oklch(93% 0.06 235);
}

.type-outdoor {
  color: var(--tf-primary-deep);
  background: var(--tf-primary-soft);
}

.venue-address,
.info-item,
.venue-info-row,
.venue-footer {
  display: flex;
  align-items: center;
}

.venue-address {
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.venue-address .icon,
.info-item .icon {
  margin-right: 9rpx;
}

.address-text,
.info-text {
  color: var(--tf-ink-soft);
  font-size: 25rpx;
  line-height: 1.55;
}

.venue-info-row {
  flex-wrap: wrap;
  gap: 22rpx;
  margin-bottom: 16rpx;
}

.venue-footer {
  justify-content: space-between;
}

.venue-tags {
  display: flex;
  flex: 1;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  padding: 8rpx 14rpx;
  color: var(--tf-primary-deep);
  background: oklch(94% 0.05 145);
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 750;
}

.remove-btn {
  display: flex;
  width: 54rpx;
  height: 54rpx;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  background: oklch(95% 0.04 28);
  border-radius: 50%;
}

.remove-icon {
  width: 30rpx;
  height: 30rpx;
}
