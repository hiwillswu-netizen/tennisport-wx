<!--pages/profile/profile.wxml-->
<view class="container">
  <!-- 用户信息区 -->
  <view class="user-section">
    <view class="user-card" wx:if="{{userInfo}}">
      <image class="user-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
      <view class="user-info">
        <text class="user-nickname">{{userInfo.nickName}}</text>
        <text class="user-id" wx:if="{{openid}}">ID: {{openid.slice(-8)}}</text>
      </view>
    </view>
    <view class="user-card login-card" wx:else bindtap="getUserProfile" hover-class="user-card-hover">
      <view class="login-avatar">
        <text class="login-icon">👤</text>
      </view>
      <view class="user-info">
        <text class="login-text">点击登录</text>
        <text class="login-tip">登录后享受更多功能</text>
      </view>
      <text class="login-arrow">›</text>
    </view>
  </view>

  <!-- 我的数据 -->
  <view class="stats-section">
    <view class="stats-item" bindtap="goToMyMatches" hover-class="stats-item-hover">
      <text class="stats-value">{{myMatchesCount}}</text>
      <text class="stats-label">发布约球</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item" bindtap="goToMyJoins" hover-class="stats-item-hover">
      <text class="stats-value">{{myJoinsCount}}</text>
      <text class="stats-label">参与约球</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item" bindtap="goToFavorites" hover-class="stats-item-hover">
      <text class="stats-value">{{collectCount}}</text>
      <text class="stats-label">收藏场馆</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-group">
      <view class="menu-item" bindtap="goToMyMatches" hover-class="menu-item-hover">
        <text class="menu-icon">📝</text>
        <text class="menu-title">我的发布</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToMyJoins" hover-class="menu-item-hover">
        <text class="menu-icon">🎾</text>
        <text class="menu-title">我参与的</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToFavorites" hover-class="menu-item-hover">
        <text class="menu-icon">❤️</text>
        <text class="menu-title">收藏场馆</text>
        <view class="menu-badge" wx:if="{{collectCount > 0}}">{{collectCount}}</view>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="menu-group">
      <view class="menu-item" bindtap="goToFeedback" hover-class="menu-item-hover">
        <text class="menu-icon">💬</text>
        <text class="menu-title">意见反馈</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToAbout" hover-class="menu-item-hover">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-title">关于我们</text>
        <text class="menu-arrow">›</text>
      </view>
      <button class="menu-item contact-btn" open-type="contact" hover-class="menu-item-hover">
        <text class="menu-icon">🎧</text>
        <text class="menu-title">联系客服</text>
      </button>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text class="version-text">TennisFind v1.0.0</text>
    <text class="powered">Powered by CloudBase</text>
  </view>
</view>
