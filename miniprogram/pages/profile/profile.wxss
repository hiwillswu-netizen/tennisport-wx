/* pages/profile/profile.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.user-section {
  background: linear-gradient(135deg, #16a34a, #22c55e);
  padding: 60rpx 30rpx 80rpx;
}

.user-card {
  display: flex;
  align-items: center;
}

.user-card-hover {
  opacity: 0.9;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  background-color: rgba(255, 255, 255, 0.2);
}

.user-info {
  flex: 1;
  padding-left: 24rpx;
  display: flex;
  flex-direction: column;
}

.user-nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-card {
  background-color: rgba(255, 255, 255, 0.15);
  padding: 30rpx;
  border-radius: 16rpx;
}

.login-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-icon {
  font-size: 48rpx;
}

.login-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 4rpx;
}

.login-tip {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-arrow {
  color: rgba(255, 255, 255, 0.6);
  font-size: 40rpx;
}

.stats-section {
  display: flex;
  align-items: center;
  background-color: #fff;
  margin: -40rpx 20rpx 20rpx;
  border-radius: 16rpx;
  padding: 30rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 0;
}

.stats-item-hover {
  background-color: #f9fafb;
}

.stats-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: #f0f0f0;
}

.stats-value {
  font-size: 40rpx;
  font-weight: 600;
  color: #16a34a;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 24rpx;
  color: #666;
}

.menu-section {
  padding: 0 20rpx;
}

.menu-group {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item-hover {
  background-color: #f9fafb;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-title {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-badge {
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  background-color: #ef4444;
  color: #fff;
  font-size: 22rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.contact-btn {
  width: 100%;
  background-color: transparent;
  border: none;
  text-align: left;
  line-height: normal;
  font-size: inherit;
  margin: 0;
  padding: 30rpx;
}

.contact-btn::after {
  border: none;
}

.version-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.version-text {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.powered {
  font-size: 22rpx;
  color: #ccc;
}
